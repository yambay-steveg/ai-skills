#!/usr/bin/env python3
"""cardctl — drive the session-card system.

A card is a markdown note with YAML frontmatter:

    ---
    type: project         # project | program (bug | idea | decision optional)
    title: Session card system
    status: in-progress
    tags: [area/tools]                                # facet tags only
    program: "[[Work Ops]]"                           # hierarchy via wikilinks
    sessionId: 81cd5424-8257-4374-b4e9-2b5986a0b8b2   # optional pin
    paths:                                            # folders the card works on (absolute)
      - /Users/steve/Source/work/yambay-steveg/claude-code-steveg/active/session-card-system
    ---
    body / notes

Commands:
  cardctl launch <card.md>          Open the card's `paths` as one VSCode window and resume the
                                    pinned session (or start a fresh one if none / --new).
  cardctl launch <card.md> --new    Force a fresh session even if the card pins one.
  cardctl link   <card.md>          Find the newest Claude session under the card's folder and
                                    write its id back into the card's `sessionId` frontmatter.
  cardctl set-status <card.md> <s>  Set the card's lifecycle status (the single writer of that
                                    field; surfaces like the board delegate here, never edit files).
  cardctl list [--json]             List every card across the Cards/ folders. With --json, emit a
                                    JSON array (one object per card) the board consumes directly.
  cardctl focus <card.md>           Bring the card's VS Code window to the front (macOS; needs
                                    Accessibility permission — best-effort, never crashes).

macOS only for now. `code` and `open` are resolved by absolute path (works under GUI launchers
like Obsidian Shell Commands, which run with a minimal PATH).
"""
import argparse
import datetime
import glob
import json
import os
import re
import shutil
import subprocess
import sys
import time
from pathlib import Path


def find_exe(name, fallbacks):
    """Resolve an executable robustly — GUI launchers (e.g. Obsidian Shell Commands)
    run with a minimal PATH, so fall back to well-known absolute locations."""
    found = shutil.which(name)
    if found:
        return found
    for fb in fallbacks:
        if Path(fb).exists():
            return fb
    return name  # last resort: let subprocess fail with a clear error


CODE = find_exe("code", ["/opt/homebrew/bin/code", "/usr/local/bin/code"])
OPEN = find_exe("open", ["/usr/bin/open"])
OSASCRIPT = find_exe("osascript", ["/usr/bin/osascript"])

PROJECTS = Path.home() / ".claude" / "projects"
CACHE = Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache")) / "session-cards"
URI = "vscode://anthropic.claude-code/open?session={sid}"
URI_NEW = "vscode://anthropic.claude-code/open"

# Where cards live, per Domain (R10): the Obsidian vault's Cards/ folder.
CARDS_DIRS = {
    "work": Path.home() / "Source/work/yambay-steveg/work-knowledge/Cards",
    "personal": Path.home() / "Source/personal/knowledge/personal-knowledge/Cards",
}
BUTTON_BAR = ("`BUTTON[launch-card]` `BUTTON[new-session]` "
              "`BUTTON[launch-dangerous]` `BUTTON[pin-session]`")

# The card lifecycle vocabulary. `set-status` accepts only these; `reconcile`
# keys off `archived`. Surfaces (e.g. the board) must change status through
# cardctl, not by writing the file, so this stays the single source of truth.
CARD_STATUSES = ["backlog", "in-progress", "on-hold", "done", "archived"]


def die(msg):
    print(f"cardctl: {msg}", file=sys.stderr)
    sys.exit(1)


def parse_fm(fm):
    """Minimal frontmatter parser for the card schema: scalars, inline lists
    (`tags: [a, b]`) and block lists (`paths:` then `  - item`). No deps."""
    data, key = {}, None
    for raw in fm.splitlines():
        if not raw.strip() or raw.lstrip().startswith("#"):
            continue
        if raw[:1] in (" ", "\t") and raw.strip().startswith("- "):
            if key is not None:
                data.setdefault(key, [])
                if isinstance(data[key], list):
                    data[key].append(raw.strip()[2:].strip())
            continue
        if ":" in raw:
            k, _, v = raw.partition(":")
            key, v = k.strip(), v.strip()
            if v == "":
                data[key] = []                      # block list to follow
            elif v.startswith("[") and v.endswith("]"):
                data[key] = [x.strip() for x in v[1:-1].split(",") if x.strip()]
            else:
                data[key] = v
    return data


def read_card(path):
    text = Path(path).read_text()
    if not text.startswith("---"):
        die(f"{path}: no YAML frontmatter")
    _, fm, _body = text.split("---", 2)
    return parse_fm(fm), text


def expand(p):
    return str(Path(os.path.expanduser(p)).resolve())


def unquote(v):
    """Strip a single layer of surrounding matching quotes from a scalar (the way
    `cmd_which` does), leaving unquoted values untouched."""
    v = str(v).strip()
    return v[1:-1] if len(v) >= 2 and v[0] == v[-1] and v[0] in "\"'" else v


def unwrap_wikilink(v):
    """`[[Target]]` / `[[Target|Alias]]` → `Target`; anything else returned as-is
    (after unquoting). The board wants the bare target, not the display alias."""
    v = unquote(v)
    m = re.match(r"^\[\[(.+?)\]\]$", v)
    if m:
        return m.group(1).split("|", 1)[0].strip()
    return v


def area_of(tags):
    """First `area/<slug>` tag's slug (e.g. `area/tools` → `tools`), else ''."""
    for t in tags or []:
        t = t.strip()
        if t.startswith("area/"):
            return t[len("area/"):]
    return ""


def encode_cwd(cwd):
    """Claude encodes a project cwd by replacing '/' with '-'."""
    return cwd.replace("/", "-")


def origin_of_session(sid):
    """Locate a session's transcript and return the cwd it was created in."""
    hits = glob.glob(str(PROJECTS / "*" / f"{sid}.jsonl"))
    if not hits:
        return None
    with open(hits[0]) as f:
        for line in f:
            try:
                rec = json.loads(line)
            except ValueError:
                continue
            if isinstance(rec, dict) and rec.get("cwd"):
                return rec["cwd"]
    # fall back to the encoded dir name (lossy, but better than nothing)
    return None


def ensure_primary_folder(fm):
    """If the card's primary path (paths[0], the activity folder) doesn't exist yet, create it
    (+ a stub README) so a GUI-created card launches cleanly — make a card, click ▶, work.
    Only when the parent already exists, so a typo'd path isn't fabricated deep."""
    paths = fm.get("paths") or []
    if not paths:
        return
    prim = Path(expand(paths[0]))
    if prim.exists() or not prim.parent.is_dir():
        return
    prim.mkdir()
    title = str(fm.get("title") or prim.name).strip().strip("\"'")
    readme = prim / "README.md"
    if not readme.exists():
        readme.write_text(f"# {title}\n\nActivity folder — sessions root here; working state lives here.\n")
    print(f"  created activity folder {prim}")


def build_workspace(card_path, fm, sid, dangerous=False):
    paths = [expand(p) for p in (fm.get("paths") or [])]

    # When resuming, ensure the session's origin folder is in the workspace, else the
    # resume lookup may not find it (it is scoped to the open workspace folders).
    if sid:
        origin = origin_of_session(sid)
        if origin and expand(origin) not in paths:
            paths.insert(0, expand(origin))

    folders = [p for p in dict.fromkeys(paths) if Path(p).is_dir()]
    if not folders:
        die(f"{card_path}: no existing folders in `paths`")

    # window.title makes each generated window identifiable by its card, so `focus`
    # (and launch's window-raise) can target the right one — VS Code's resume URI has
    # no window-targeting param. Merge, don't overwrite, so --dangerous settings survive.
    title = unquote(fm.get("title") or Path(card_path).stem)
    settings = {"window.title": f"{title} — ${{rootName}}"}

    # --dangerous: workspace-scoped settings so the Claude extension starts in
    # bypassPermissions mode for THIS window only (regenerated each launch).
    if dangerous:
        settings.update({
            "claudeCode.allowDangerouslySkipPermissions": True,
            "claudeCode.initialPermissionMode": "bypassPermissions",
        })

    CACHE.mkdir(parents=True, exist_ok=True)
    ws = CACHE / f"{Path(card_path).stem}.code-workspace"
    ws.write_text(json.dumps(
        {"folders": [{"name": Path(p).name, "path": p} for p in folders], "settings": settings},
        indent=2,
    ))
    return ws, folders


def primary_context(fm):
    """First existing folder in `paths` — where this card's sessions are created (cwd)."""
    for p in (fm.get("paths") or []):
        if Path(expand(p)).is_dir():
            return expand(p)
    return None


def sessions_for_folder(folder):
    """Transcripts created with cwd=folder, newest first."""
    proj = PROJECTS / encode_cwd(folder)
    return sorted(proj.glob("*.jsonl"), key=lambda p: p.stat().st_mtime, reverse=True)


def first_user_msg(path):
    """A short preview of a session's first human message (for the pick list)."""
    try:
        with open(path) as f:
            for line in f:
                try:
                    rec = json.loads(line)
                except ValueError:
                    continue
                if not (isinstance(rec, dict) and rec.get("type") == "user"):
                    continue
                c = (rec.get("message") or {}).get("content")
                if isinstance(c, list):
                    c = " ".join(p.get("text", "") for p in c
                                 if isinstance(p, dict) and p.get("type") == "text")
                c = (c or "").strip()
                if c and not c.startswith("<") and "command-" not in c[:40] \
                        and not c.lower().startswith("caveat"):
                    return c[:70]
    except OSError:
        pass
    return "(no preview)"


def pick_session(folder, sess):
    """Interactive chooser (terminal only). Returns a sid, or None for 'new'."""
    print(f"sessions under {folder}:")
    for i, p in enumerate(sess[:9], 1):
        ts = datetime.datetime.fromtimestamp(p.stat().st_mtime).strftime("%d %b %H:%M")
        print(f"  {i}) {ts}  {first_user_msg(p)}")
    print("  0) start a new session")
    try:
        choice = input("choose [1]: ").strip() or "1"
    except EOFError:
        return sess[0].stem  # non-interactive (e.g. a button) → latest
    if choice == "0":
        return None
    try:
        idx = int(choice) - 1
        if 0 <= idx < len(sess[:9]):
            return sess[idx].stem
    except ValueError:
        pass
    return sess[0].stem


def resolve_session(fm, args):
    """Decide which session to resume (sid) and why (mode). None sid → start fresh.
    Precedence: --new → fresh; pinned `sessionId` → that; else newest under the
    card's context folder (--pick to choose); else fresh (R14)."""
    if args.new:
        return None, "new (forced)"
    pin = fm.get("sessionId")
    if isinstance(pin, str) and pin.strip():
        return pin.strip(), "pinned"
    folder = primary_context(fm)
    if folder:
        sess = sessions_for_folder(folder)
        if sess:
            if args.pick:
                return pick_session(folder, sess), "picked"
            return sess[0].stem, "latest for folder"
    return None, "new (no prior session)"


def activate_vscode():
    """Bring VS Code to the front before firing the resume URI. The
    `vscode://anthropic.claude-code/open?session=` URI is delivered to whatever
    window is frontmost (no window-targeting param exists), so when launched from
    Obsidian — which is frontmost — the resume can land in the wrong window. This
    re-asserts VS Code (whose newly-opened window is its front window) as the
    frontmost app, closing the common case of the race. The deterministic fix
    (raise the specific window by title) is the separate window-targeting work."""
    try:
        subprocess.run([OSASCRIPT, "-e",
                        'tell application "Visual Studio Code" to activate'],
                       check=False, timeout=5)
    except (OSError, subprocess.SubprocessError):
        pass  # best-effort focus nudge; never block the launch on it


def cmd_launch(args):
    fm, _ = read_card(args.card)
    ensure_primary_folder(fm)  # GUI-created card with no folder yet → create it, then launch
    sid, mode = resolve_session(fm, args)
    ws, folders = build_workspace(args.card, fm, sid, dangerous=args.dangerous)

    print(f"opening {len(folders)} folder(s){' [DANGEROUS: bypassPermissions]' if args.dangerous else ''}:")
    for p in folders:
        print(f"  - {p}")
    subprocess.run([CODE, str(ws)], check=True)
    time.sleep(args.delay)
    activate_vscode()        # make the new VS Code window frontmost before the URI
    time.sleep(0.4)          # let the activation settle so the URI lands on it

    if sid:
        print(f"resuming session {sid}  ({mode})")
        subprocess.run([OPEN, URI.format(sid=sid)], check=True)
    else:
        print(f"starting a new session  ({mode})")
        subprocess.run([OPEN, URI_NEW], check=True)
        print(f"  → pin it later if you want with:  cardctl link {args.card}")


UUID_RE = re.compile(r"`([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12})`")


def session_date(sid):
    """Date a session ran, from its transcript mtime (for the ## Sessions log)."""
    hits = glob.glob(str(PROJECTS / "*" / f"{sid}.jsonl"))
    if hits:
        return datetime.datetime.fromtimestamp(Path(hits[0]).stat().st_mtime).strftime("%d %b %Y")
    return ""


def cmd_link(args):
    """Pin a session as the card's `sessionId` AND log it under the card's `## Sessions`
    history (newest first; an AI fills in 'what it did'). Re-pin freely — the previous pin
    stays logged. Pick the session: `--session <id>` | `--current` (the running session) |
    newest transcript under the card's folder (`--cwd` to point elsewhere)."""
    fm, text = read_card(args.card)

    if args.session:
        sid = args.session.strip()
    elif args.current:
        tx = glob.glob(str(PROJECTS / "*" / "*.jsonl"))
        if not tx:
            die("no session transcripts found")
        sid = Path(max(tx, key=lambda p: Path(p).stat().st_mtime)).stem
        print(f"current session: {sid}")
    else:
        origin = args.cwd or next((expand(p) for p in (fm.get("paths") or [])
                                   if Path(expand(p)).is_dir()), None)
        if not origin:
            die(f"{args.card}: no folder to search — pass --session <id> or --cwd")
        proj = PROJECTS / encode_cwd(origin)
        sess = sorted(proj.glob("*.jsonl"), key=lambda p: p.stat().st_mtime, reverse=True)
        if not sess:
            die(f"no sessions found under {origin} (looked in {proj}); "
                f"pass --session <id> for a session that ran elsewhere")
        sid = sess[0].stem
        print(f"newest session under {origin}: {sid}")

    old = fm.get("sessionId")
    old = old.strip() if isinstance(old, str) and old.strip() else None

    # Sessions already logged in the body (so re-pinning doesn't duplicate).
    logged = set(UUID_RE.findall(text))
    # Newest-first: the new current, then the session it displaced (if not already logged).
    add = [i for i in ([sid] + ([old] if old and old != sid else [])) if i not in logged]
    # `sessionId` (frontmatter) marks the current pin; the log is just id — date (newest first),
    # and an AI fills in the "— what it did" note. No (current) marker to go stale.
    entries = [f"- `{i}` — {session_date(i) or '?'}" for i in add]

    lines = text.splitlines(keepends=True)
    out, in_fm, seen_open, sid_set, inserted = [], False, False, False, (not entries)
    for ln in lines:
        if ln.strip() == "---":
            if not seen_open:
                seen_open = in_fm = True
                out.append(ln); continue
            if in_fm:
                if not sid_set:
                    out.append(f"sessionId: {sid}\n")
                in_fm = False
                out.append(ln); continue
        if in_fm:
            if ln.startswith("sessionId:"):
                out.append(f"sessionId: {sid}\n"); sid_set = True; continue
            out.append(ln); continue
        out.append(ln)
        if not inserted and ln.strip() == "## Sessions":
            out += [e + "\n" for e in entries]
            inserted = True
    if not inserted:  # no ## Sessions section yet — append one
        if out and not out[-1].endswith("\n"):
            out.append("\n")
        out.append("\n## Sessions\n\n")
        out += [e + "\n" for e in entries]
    Path(args.card).write_text("".join(out))
    print(f"pinned {sid}; logged {len(entries)} session(s) under ## Sessions"
          + (f" (previous {old} kept in history)" if old and old != sid else ""))


def card_under_cards_dirs(path):
    """True if `path` resolves inside one of the configured Cards/ folders — the
    guard that keeps `set-status` (and any surface delegating to it) from editing
    arbitrary files."""
    target = expand(path)
    return any(target == expand(cd) or target.startswith(expand(cd) + os.sep)
               for cd in CARDS_DIRS.values())


def set_status_in_text(text, status):
    """Return `text` with its frontmatter `status:` set to `status`, leaving the
    rest byte-for-byte (surgical single-line edit — body, other fields, quoting and
    key order untouched, so the vault git diff stays minimal). Replaces a `status:`
    line in place; if the frontmatter has none, inserts one before the closing `---`."""
    out, in_fm, seen_open, wrote = [], False, False, False
    for ln in text.splitlines(keepends=True):
        if ln.strip() == "---":
            if not seen_open:
                seen_open = in_fm = True
                out.append(ln); continue
            if in_fm:
                if not wrote:
                    out.append(f"status: {status}\n"); wrote = True
                in_fm = False
                out.append(ln); continue
        if in_fm and ln.startswith("status:"):
            out.append(f"status: {status}\n"); wrote = True; continue
        out.append(ln)
    return "".join(out)


def cmd_set_status(args):
    """Set a card's lifecycle `status` — the one board-owned field cardctl writes on
    demand (R10: surfaces never edit the card file directly; they go through here).
    Flips the field only; folder moves for `archived` stay with `reconcile`."""
    status = args.status.strip()
    if status not in CARD_STATUSES:
        die(f"invalid status {status!r} (choose: {', '.join(CARD_STATUSES)})")
    if not Path(args.card).is_file():
        die(f"{args.card}: no such card")
    if not card_under_cards_dirs(args.card):
        die(f"{args.card}: not inside a configured Cards/ folder")
    fm, text = read_card(args.card)
    old = str(fm.get("status") or "").strip()
    if old == status:
        print(f"{Path(args.card).name}: status already {status}")
        return
    Path(args.card).write_text(set_status_in_text(text, status))
    print(f"{Path(args.card).name}: status {old or '?'} → {status}")


def cmd_new(args):
    cards = CARDS_DIRS.get(args.domain)
    if cards is None:
        die(f"unknown domain {args.domain!r} (choose: {', '.join(CARDS_DIRS)})")
    cards.mkdir(parents=True, exist_ok=True)
    dest = cards / f"{args.slug}.md"
    if dest.exists() and not args.force:
        die(f"{dest} already exists (use --force to overwrite)")

    tags = ([args.area] if args.area else []) + ([f"jira/{args.jira}"] if args.jira else [])
    paths = [expand(p) for p in (args.path or [])]

    # The primary path (paths[0]) is the activity folder — where sessions root (cwd) and
    # working state lives. Create it for a brand-new activity so it can be a workspace folder.
    if args.make_folder and paths:
        prim = Path(paths[0])
        prim.mkdir(parents=True, exist_ok=True)
        readme = prim / "README.md"
        if not readme.exists():
            readme.write_text(f"# {args.title}\n\n**Started:** {datetime.date.today().isoformat()} "
                              "(AWST)\n\nActivity folder — sessions root here; working state lives here.\n")
        print(f"  created activity folder {prim}")
    for p in paths:
        if not Path(p).is_dir():
            print(f"cardctl: warning — path does not exist yet: {p}", file=sys.stderr)

    # Human glance fields (shown on the board) first; plumbing (cardctl) last.
    # json.dumps gives YAML-safe double-quoting; ensure_ascii=False keeps em-dashes etc.
    # literal in the file (YAML would parse \uXXXX, but the raw card stays readable).
    def yq(s):
        return json.dumps(s or "", ensure_ascii=False)
    fm = [f"type: {args.type}", f"title: {args.title}", f"status: {args.status}",
          f"summary: {yq(args.summary)}",
          f"latest: {yq(args.latest)}",
          f"tags: [{', '.join(tags)}]"]
    if args.program:
        fm.append(f'program: "[[{args.program}]]"')
    if args.session:
        fm.append(f"sessionId: {args.session}")
    fm.append("paths:")
    fm += [f"  - {p}" for p in paths] or ["  - "]

    sessions = "\n## Sessions\n\n"
    if args.session:
        sessions += f"- `{args.session}` — {session_date(args.session) or '?'}  — (current)\n"
    body = (f"\n{BUTTON_BAR}\n\n{args.summary or '<one line; deep state lives in the activity folder>'}\n"
            f"{sessions}")
    dest.write_text("---\n" + "\n".join(fm) + "\n---\n" + body)
    print(f"created {dest}")
    if args.session:
        print(f"  pinned session {args.session}")
    print("  open it in Obsidian (Reading view) and click ▶ Launch session")


def cmd_reconcile(args):
    """R9: card status → disk. Only `archived` is filed — for cards marked **archived**,
    move their `active/<x>` folder to `archive/YYYY-MM-<x>` and update the card's path.
    `done` is deliberately NOT filed: it's complete-but-on-disk (off the board, folder
    stays in active/, trivially reopenable). Archiving is a separate, explicit step.
    Cross-repo: cards live in the vault, folders in the task repos. Dry-run by default."""
    closing = {"archived"}
    prefix = datetime.date.today().strftime("%Y-%m-")

    cards = []
    for cd in CARDS_DIRS.values():
        if cd.is_dir():
            cards += sorted(cd.glob("*.md"))

    # Folders referenced by a still-active card must NOT be archived (R14 Pattern B).
    parsed, live_refs = [], set()
    for c in cards:
        fm, text = read_card(c)
        status = str(fm.get("status") or "").strip().lower()
        paths = [expand(p) for p in (fm.get("paths") or [])]
        parsed.append((c, status, paths, fm, text))
        if status not in closing:
            live_refs.update(paths)

    todo = []
    for c, status, paths, fm, text in parsed:
        if status not in closing:
            continue
        for p, raw in zip(paths, (fm.get("paths") or [])):
            if "/active/" not in p or not Path(p).is_dir():
                continue
            if p in live_refs:
                print(f"SKIP (shared with a live card): {p}  [{c.name}]")
                continue
            repo, _, _ = p.partition("/active/")
            leaf = Path(p).name
            target = f"{repo}/archive/{prefix}{leaf}"
            todo.append((c, p, raw, repo, leaf, target, text))

    if not todo:
        print("reconcile: nothing to do.")
        return
    for c, p, raw, repo, leaf, target, text in todo:
        old_proj = PROJECTS / encode_cwd(p)
        n_tx = len(list(old_proj.glob("*.jsonl"))) if old_proj.is_dir() else 0
        tx_note = f"  (+{n_tx} session transcript(s) relocated)" if n_tx else ""
        print(f"{'APPLY' if args.apply else 'DRY '}  {p}\n        → {target}{tx_note}   [{c.name}]")
        if not args.apply:
            continue
        Path(repo, "archive").mkdir(exist_ok=True)
        rel_src = p[len(repo) + 1:]
        rel_dst = target[len(repo) + 1:]
        r = subprocess.run(["git", "-C", repo, "mv", rel_src, rel_dst])
        if r.returncode != 0:  # folder not tracked — fall back to plain move + add
            subprocess.run(["mv", p, target], check=True)
            subprocess.run(["git", "-C", repo, "add", rel_dst], check=True)
        subprocess.run(["git", "-C", repo, "commit", "-q", "-m", f"Archive: {leaf}"], check=True)
        # Relocate the activity folder's session transcripts so the archived folder still
        # resolves to its sessions (resume keeps working post-archive).
        if old_proj.is_dir():
            new_proj = PROJECTS / encode_cwd(target)
            new_proj.mkdir(parents=True, exist_ok=True)
            for item in old_proj.iterdir():
                subprocess.run(["mv", str(item), str(new_proj / item.name)], check=True)
            try:
                old_proj.rmdir()
            except OSError:
                pass
        # update the card's path (vault file; rides the vault auto-backup)
        new_text = c.read_text().replace(f"- {raw}", f"- {target}", 1)
        c.write_text(new_text)
        print(f"        moved + committed in {Path(repo).name}; card path updated{tx_note}")
    if not args.apply:
        print("\n(dry run — rerun with --apply to perform the moves)")


# ── deploy ────────────────────────────────────────────────────────────────────
# Single-source the deployable surfaces (R10 "one management home"): the canonical
# copies live in this repo under deploy/; `deploy` pushes them out to each vault and
# to ~/bin. Surface files (board.base, card.md) are copied; the shared .obsidian/*.json
# files are MERGED by id/key so a vault's own settings (and other plugins' config) are
# never clobbered. Idempotent — only writes when content actually changes.

# Source tree: the repo copy when run from it, else the canonical work home (R10).
REPO = Path(__file__).resolve().parent
if not (REPO / "deploy").is_dir():
    REPO = Path.home() / "Source/work/yambay-steveg/ai-skills/session-cards"
DEPLOY_SRC = REPO / "deploy"
CARDCTL_SRC = REPO / "cardctl"
HOOK_SRC = REPO.parent / "bin" / "session-start-hook.sh"
BIN = Path.home() / "bin"
VAULT_ROOTS = {d: cards.parent for d, cards in CARDS_DIRS.items()}


def _load_json(p):
    p = Path(p)
    return json.loads(p.read_text()) if p.is_file() else {}


def merge_list_by_key(existing, ours, key="id"):
    """Merge `ours` into `existing` by `key`: our version replaces a match in place,
    new items append, everything else is preserved untouched. Returns (merged, changed)."""
    ours_by = {it[key]: it for it in ours}
    out, seen = [], set()
    for it in existing:
        k = it.get(key)
        if k in ours_by:
            out.append(ours_by[k]); seen.add(k)
        else:
            out.append(it)
    for it in ours:
        if it[key] not in seen:
            out.append(it)
    return out, out != existing


def merge_templater(existing, frag):
    """Ensure the folder-template wiring is present without clobbering other Templater
    settings. Sets the enabling flags, keeps an existing templates_folder if already set,
    and merges our folder_templates entry by `folder`. Returns (merged, changed)."""
    out = dict(existing)
    out.setdefault("templates_folder", frag["templates_folder"])
    out["trigger_on_file_creation"] = frag["trigger_on_file_creation"]
    out["enable_folder_templates"] = frag["enable_folder_templates"]
    ft, ours = list(out.get("folder_templates") or []), frag["folder_templates"]
    out["folder_templates"], _ = merge_list_by_key(ft, ours, key="folder")
    return out, out != existing


# Each surface: (label, dest-relative-to-vault, kind, source). kind drives the merge.
DEPLOY_SURFACES = [
    ("board.base",     "Cards/board.base",       "copy", "Cards/board.base"),
    ("card template",  "Templates/card.md",      "copy", "Templates/card.md"),
    ("shell commands", ".obsidian/plugins/obsidian-shellcommands/data.json",
     "array:shell_commands", "fragments/shellcommands.commands.json"),
    ("meta-bind buttons", ".obsidian/plugins/obsidian-meta-bind-plugin/data.json",
     "array:buttonTemplates", "fragments/metabind.buttons.json"),
    ("templater config", ".obsidian/plugins/templater-obsidian/data.json",
     "templater", "fragments/templater.folder-template.json"),
]


def _deploy_surface(vault, dest_rel, kind, src_rel, apply):
    """Compute (and optionally apply) one surface. Returns 'create' | 'update' |
    'unchanged' | a 'skip: …' note."""
    dst = vault / dest_rel
    src = DEPLOY_SRC / src_rel
    if not src.is_file():
        return f"skip: missing source {src}"

    if kind == "copy":
        new_text = src.read_text()
        if dst.is_file() and dst.read_text() == new_text:
            return "unchanged"
        action = "update" if dst.is_file() else "create"
        if apply:
            dst.parent.mkdir(parents=True, exist_ok=True)
            dst.write_text(new_text)
        return action

    # JSON merge surfaces — never clobber sibling settings.
    if kind.startswith("array:") and not dst.parent.is_dir():
        return "skip: plugin not installed"
    existing = _load_json(dst)
    ours = json.loads(src.read_text())
    if kind.startswith("array:"):
        prop = kind.split(":", 1)[1]
        merged, changed = merge_list_by_key(existing.get(prop, []), ours)
        new = dict(existing); new[prop] = merged
    elif kind == "templater":
        new, changed = merge_templater(existing, ours)
    else:
        return f"skip: unknown kind {kind}"
    if not changed:
        return "unchanged"
    action = "update" if dst.is_file() else "create"
    if apply:
        dst.parent.mkdir(parents=True, exist_ok=True)
        dst.write_text(json.dumps(new, indent=2) + "\n")
    return action


def _deploy_bin(apply):
    """Sync the engine + hook to ~/bin (global, not per-domain). Returns [(name, action)]."""
    out = []
    for src, name in [(CARDCTL_SRC, "cardctl"), (HOOK_SRC, "session-start-hook.sh")]:
        dst = BIN / name
        if not Path(src).is_file():
            out.append((name, f"skip: missing source {src}")); continue
        new_text = Path(src).read_text()
        if dst.is_file() and dst.read_text() == new_text:
            out.append((name, "unchanged")); continue
        action = "update" if dst.is_file() else "create"
        if apply:
            BIN.mkdir(parents=True, exist_ok=True)
            dst.write_text(new_text)
            os.chmod(dst, 0o755)
        out.append((name, action))
    return out


def cmd_deploy(args):
    if not DEPLOY_SRC.is_dir():
        die(f"deploy sources not found at {DEPLOY_SRC} (run from the ai-skills repo)")
    domains = list(CARDS_DIRS) if args.domain == "all" else [args.domain]
    tag = "APPLY" if args.apply else "DRY "
    any_change = False

    for d in domains:
        vault = VAULT_ROOTS[d]
        print(f"\n{d}  ({vault})")
        if not vault.is_dir():
            print(f"  skip: vault not found"); continue
        for label, dest_rel, kind, src_rel in DEPLOY_SURFACES:
            action = _deploy_surface(vault, dest_rel, kind, src_rel, args.apply)
            any_change |= action in ("create", "update")
            print(f"  {tag}  {action:9}  {label:18}  {dest_rel}")

    print(f"\n~/bin  ({BIN})")
    for name, action in _deploy_bin(args.apply):
        any_change |= action in ("create", "update")
        print(f"  {tag}  {action:9}  {name}")

    if not args.apply and any_change:
        print("\n(dry run — rerun with --apply to write the changes)")
    elif not any_change:
        print("\ndeploy: everything already up to date.")


CACHE_RE = re.compile(r"<!--\s*card:\s*(.+?)\s*-->")   # legacy README marker (migrated away from)
CARD_DOTFILE = ".card"


def card_matches_folder(fm, folder):
    """True if the card's paths include `folder` (or `folder` is inside one)."""
    folder = expand(folder)
    for p in (fm.get("paths") or []):
        ep = expand(p)
        if folder == ep or folder.startswith(ep + "/"):
            return True
    return False


def find_card_for(folder):
    """Reverse-lookup the card whose `paths` cover `folder` (R: session→card link).
    Fast path: a validated card path in a `.card` dotfile in the folder.
    Fallback: scan every Cards/ dir. Single source of truth = the cards' `paths`."""
    folder = expand(folder)
    dot = Path(folder) / CARD_DOTFILE
    if dot.is_file():
        cached = dot.read_text().strip()
        if cached and Path(cached).is_file():
            fm, _ = read_card(cached)
            if card_matches_folder(fm, folder):   # validate — cache can go stale (cross-repo)
                return Path(cached)
    for cd in CARDS_DIRS.values():
        if cd.is_dir():
            for c in sorted(cd.glob("*.md")):
                fm, _ = read_card(c)
                if card_matches_folder(fm, folder):
                    return c
    return None


def write_card_cache(folder, card_path):
    """Record/refresh the card back-pointer in a dedicated `.card` dotfile — a local cache that
    never touches the folder's notes (R10: 'never touch a vault's notes'). Idempotent (no write,
    no git churn, if already correct). Also migrates away any legacy `<!-- card: … -->` marker an
    older cardctl wrote into the folder's README.md."""
    dot = Path(folder) / CARD_DOTFILE
    if not (dot.is_file() and dot.read_text().strip() == str(card_path)):
        dot.write_text(str(card_path) + "\n")
    # one-time migration: strip a legacy marker so it stops polluting real READMEs/specs.
    readme = Path(folder) / "README.md"
    if readme.is_file():
        text = readme.read_text()
        if CACHE_RE.search(text):
            kept = [l for l in text.splitlines() if not CACHE_RE.search(l)]
            readme.write_text("\n".join(kept) + ("\n" if text.endswith("\n") else ""))


def open_actions(folder, limit=6):
    """Unchecked `- [ ]` items from the folder README's `## Open actions` (if any)."""
    readme = Path(folder) / "README.md"
    if not readme.is_file():
        return []
    out, in_sec = [], False
    for l in readme.read_text().splitlines():
        if l.startswith("## "):
            in_sec = l.strip().lower().startswith("## open")
            continue
        if in_sec and l.strip().startswith("- [ ]"):
            out.append(l.strip())
    return out[:limit]


def cmd_which(args):
    folder = expand(args.folder or os.getcwd())
    card = find_card_for(folder)
    if not card:
        if not args.quiet:
            print(f"cardctl: no card references {folder}", file=sys.stderr)
        sys.exit(1)
    if args.record:
        write_card_cache(folder, str(card))
    if args.path_only:
        print(str(card))
        return
    fm, _ = read_card(card)
    def unq(v):
        v = str(v).strip()
        return v[1:-1] if len(v) >= 2 and v[0] == v[-1] and v[0] in "\"'" else v
    print(f"Active card: {unq(fm.get('title', card.stem))}  [{card}]")
    if fm.get("status"):
        print(f"status: {unq(fm['status'])}")
    if fm.get("latest"):
        print(f"latest: {unq(fm['latest'])}")
    acts = open_actions(folder)
    if acts:
        print("open actions:")
        for a in acts:
            print(f"  {a}")


def card_to_dict(path, source):
    """The board's card model for one card file (scalars unquoted, wikilinks
    unwrapped, `area` derived). `source` is the vault domain key (work/personal)."""
    fm, _ = read_card(path)
    tags = fm.get("tags") if isinstance(fm.get("tags"), list) else []
    paths = fm.get("paths") if isinstance(fm.get("paths"), list) else []
    p = Path(path)
    return {
        "filePath": str(p.resolve()),
        "fileName": p.stem,
        "title": unquote(fm.get("title") or p.stem),
        "status": unquote(fm.get("status") or ""),
        "summary": unquote(fm.get("summary") or ""),
        "latest": unquote(fm.get("latest") or ""),
        "tags": [t.strip() for t in tags],
        "program": unwrap_wikilink(fm.get("program") or ""),
        "project": unwrap_wikilink(fm.get("project") or ""),
        "sessionId": unquote(fm.get("sessionId") or ""),
        "paths": [str(x).strip() for x in paths],
        "area": area_of(tags),
        "source": source,
    }


def cmd_list(args):
    """Read interface: enumerate every card across all CARDS_DIRS. With --json,
    emit a JSON array the board can map straight onto its card model; otherwise a
    brief human listing (title — status)."""
    cards = []
    for source, cd in CARDS_DIRS.items():
        if cd.is_dir():
            for c in sorted(cd.glob("*.md")):
                cards.append(card_to_dict(c, source))
    if args.json:
        print(json.dumps(cards, ensure_ascii=False))
    else:
        for c in cards:
            print(f"{c['title']} — {c['status'] or '?'}")


def cmd_focus(args):
    """Bring the VS Code window for a card to the front (the deterministic
    window-targeting primitive; complements launch's best-effort activate nudge).

    There is no per-window targeting param on the resume URI, so we drive macOS
    System Events: set the `Code` process frontmost, then AXRaise the window whose
    title contains the card title (`build_workspace` stamps `window.title` so each
    card's window is identifiable). Needs Accessibility permission at runtime —
    if the AppleScript fails (perm not granted, no match), we print a clear note
    and return rather than crash. Best-effort by design."""
    fm, _ = read_card(args.card)
    title = unquote(fm.get("title") or Path(args.card).stem)
    # AppleScript: raise the first Code window whose title contains the card title.
    # Escape double quotes/backslashes in the title for embedding in the script.
    safe = title.replace("\\", "\\\\").replace('"', '\\"')
    script = f'''
tell application "System Events"
    if not (exists process "Code") then error "VS Code is not running"
    tell process "Code"
        set frontmost to true
        repeat with w in windows
            if name of w contains "{safe}" then
                perform action "AXRaise" of w
                return
            end if
        end repeat
        error "no VS Code window titled like " & "{safe}"
    end tell
end tell
'''
    try:
        r = subprocess.run([OSASCRIPT, "-e", script],
                           capture_output=True, text=True, timeout=10)
    except (OSError, subprocess.SubprocessError) as e:
        print(f"cardctl: focus failed to run osascript ({e}); "
              "is this macOS?", file=sys.stderr)
        return
    if r.returncode != 0:
        # Common cause: Accessibility permission not granted to the launcher.
        print(f"cardctl: could not raise the window for {title!r}: "
              f"{r.stderr.strip() or 'unknown error'}\n"
              "  (focus needs macOS Accessibility permission for the launching app — "
              "System Settings → Privacy & Security → Accessibility.)", file=sys.stderr)
    else:
        print(f"focused VS Code window for {title!r}")


def main():
    ap = argparse.ArgumentParser(prog="cardctl", description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = ap.add_subparsers(dest="cmd", required=True)

    pl = sub.add_parser("launch", help="open card folders + resume or start its session")
    pl.add_argument("card")
    pl.add_argument("--new", action="store_true",
                    help="start a fresh session (ignore pin / latest)")
    pl.add_argument("--pick", action="store_true",
                    help="choose from the card's recent sessions (terminal only)")
    pl.add_argument("-d", "--dangerous", action="store_true",
                    help="start the session in bypassPermissions mode (skip approvals)")
    pl.add_argument("--delay", type=float, default=3.0,
                    help="seconds to wait after launching VSCode before firing the URI")
    pl.set_defaults(func=cmd_launch)

    pk = sub.add_parser("link", help="pin a session into the card (old pin → pastSessions history)")
    pk.add_argument("card")
    pk.add_argument("--session", help="pin this exact session id; "
                                      "needed for sessions that ran outside the card's folder")
    pk.add_argument("--current", action="store_true",
                    help="pin the CURRENT (running) session — the newest transcript across all projects")
    pk.add_argument("--cwd", help="folder to search for the newest session (default: first existing path)")
    pk.add_argument("--force", action="store_true", help="(accepted for compatibility; re-pin is always non-destructive now)")
    pk.set_defaults(func=cmd_link)

    pn = sub.add_parser("new", help="scaffold a card in the Domain vault's Cards/ folder")
    pn.add_argument("slug", help="card filename (kebab-case, no extension)")
    pn.add_argument("--title", required=True)
    pn.add_argument("--summary", help="one-line 'what this is' (shown on the board)")
    pn.add_argument("--latest", help="one-line current state and/or next step (shown on the board)")
    pn.add_argument("--path", action="append",
                    help="context folder (repeatable; first = primary, where sessions run)")
    pn.add_argument("--session", help="pin this session id (e.g. from `session-search`)")
    pn.add_argument("--jira", help="Jira key → jira/<KEY> tag")
    pn.add_argument("--area", help="area/* facet tag, e.g. area/v7")
    pn.add_argument("--program", help="program name → program: \"[[name]]\" link")
    pn.add_argument("--status", default="in-progress")
    pn.add_argument("--type", default="project", help="project | program (default project)")
    pn.add_argument("--domain", default="work", choices=list(CARDS_DIRS))
    pn.add_argument("--make-folder", action="store_true",
                    help="create the primary path (activity folder) + a stub README")
    pn.add_argument("--force", action="store_true", help="overwrite an existing card")
    pn.set_defaults(func=cmd_new)

    ps = sub.add_parser("set-status", help="set a card's lifecycle status (the board-owned field)")
    ps.add_argument("card")
    ps.add_argument("status", help=f"one of: {', '.join(CARD_STATUSES)}")
    ps.set_defaults(func=cmd_set_status)

    pr = sub.add_parser("reconcile",
                        help="file folders of cards marked archived (R9; dry-run by default)")
    pr.add_argument("--apply", action="store_true", help="perform the moves (default: dry run)")
    pr.set_defaults(func=cmd_reconcile)

    pd = sub.add_parser("deploy",
                        help="push the canonical surfaces (board/template/buttons/hook/engine) "
                             "to a vault + ~/bin (R10; dry-run by default)")
    pd.add_argument("domain", choices=list(CARDS_DIRS) + ["all"],
                    help="which vault to deploy to (or 'all')")
    pd.add_argument("--apply", action="store_true", help="write the changes (default: dry run)")
    pd.set_defaults(func=cmd_deploy)

    pls = sub.add_parser("list", help="list all cards across the Cards/ folders (--json for the board)")
    pls.add_argument("--json", action="store_true",
                     help="emit a JSON array (one object per card) for the board to consume")
    pls.set_defaults(func=cmd_list)

    pf = sub.add_parser("focus", help="bring the card's VS Code window to the front (macOS Accessibility)")
    pf.add_argument("card")
    pf.set_defaults(func=cmd_focus)

    pw = sub.add_parser("which", help="which card owns a folder (reverse lookup; for the session-start hook)")
    pw.add_argument("folder", nargs="?", help="folder to resolve (default: cwd)")
    pw.add_argument("--record", action="store_true", help="cache the result as a back-pointer in the folder README")
    pw.add_argument("--path-only", action="store_true", help="print just the card file path")
    pw.add_argument("--quiet", action="store_true", help="no error if no card matches (exit 1)")
    pw.set_defaults(func=cmd_which)

    args = ap.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
