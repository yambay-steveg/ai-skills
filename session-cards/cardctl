#!/usr/bin/env python3
"""cardctl — drive the session-card system.

A card is a markdown note with YAML frontmatter:

    ---
    type: project         # project | program (bug | idea | decision optional)
    title: Session card system
    status: in-progress
    tags: [area/tools]                                # facet tags only
    program: "[[Work Ops]]"                           # hierarchy via wikilinks
    sessionId: 81cd5424-8257-4374-b4e9-2b5986a0b8b2   # optional pin
    paths:                                            # folders the card works on (absolute)
      - /Users/steve/Source/work/yambay-steveg/claude-code-steveg/active/session-card-system
    ---
    body / notes

Commands:
  cardctl launch <card.md>          Open the card's `paths` as one VSCode window and resume the
                                    pinned session (or start a fresh one if none / --new).
  cardctl launch <card.md> --new    Force a fresh session even if the card pins one.
  cardctl link   <card.md>          Find the newest Claude session under the card's folder and
                                    write its id back into the card's `sessionId` frontmatter.
  cardctl set-status <card.md> <s>  Set the card's lifecycle status (the single writer of that
                                    field; surfaces like the board delegate here, never edit files).
  cardctl list [--json]             List every card across the Cards/ folders. With --json, emit a
                                    JSON array (one object per card) the board consumes directly.
  cardctl focus <card.md>           Bring the card's VS Code window to the front. Prefers a
                                    deterministic focus-by-id via Hammerspoon (`hs`); falls back
                                    to AppleScript AXRaise-by-title. Best-effort, never crashes.
  cardctl windows [--json]          List the open VS Code windows (via Hammerspoon) mapped to
                                    their cards. --json emits {available, windows:[…]} so the
                                    board can tell "no windows" apart from "engine unavailable".

macOS only for now. `code` and `open` are resolved by absolute path (works under GUI launchers
like Obsidian Shell Commands, which run with a minimal PATH).
"""
import argparse
import datetime
import glob
import json
import os
import re
import shutil
import subprocess
import sys
import time
from pathlib import Path


def find_exe(name, fallbacks):
    """Resolve an executable robustly — GUI launchers (e.g. Obsidian Shell Commands)
    run with a minimal PATH, so fall back to well-known absolute locations."""
    found = shutil.which(name)
    if found:
        return found
    for fb in fallbacks:
        if Path(fb).exists():
            return fb
    return name  # last resort: let subprocess fail with a clear error


CODE = find_exe("code", ["/opt/homebrew/bin/code", "/usr/local/bin/code"])
OPEN = find_exe("open", ["/usr/bin/open"])
OSASCRIPT = find_exe("osascript", ["/usr/bin/osascript"])
HS = find_exe("hs", ["/opt/homebrew/bin/hs", "/usr/local/bin/hs"])  # Hammerspoon CLI

PROJECTS = Path.home() / ".claude" / "projects"
CACHE = Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache")) / "session-cards"
URI = "vscode://anthropic.claude-code/open?session={sid}"
URI_NEW = "vscode://anthropic.claude-code/open"

# Where cards live, per Domain (R10): the Obsidian vault's Cards/ folder.
CARDS_DIRS = {
    "work": Path.home() / "Source/work/yambay-steveg/work-knowledge/Cards",
    "personal": Path.home() / "Source/personal/knowledge/personal-knowledge/Cards",
}

# Where a new card's own activity folder is created, per Domain. `cardctl new` makes
# <root>/<slug> as the card's primary path so a plain `new` yields a launchable card.
# Mirrors CARDS_DIRS; confirmed against existing cards (e.g. pocketsmith-integration).
ACTIVE_ROOTS = {
    "work": Path.home() / "Source/work/yambay-steveg/claude-code-steveg/active",
    "personal": Path.home() / "Source/personal/ai-tasks/active",
}
BUTTON_BAR = ("`BUTTON[launch-card]` `BUTTON[new-session]` "
              "`BUTTON[pin-session]`")

# The card lifecycle vocabulary. `set-status` accepts only these; `reconcile`
# keys off `archived`. Surfaces (e.g. the board) must change status through
# cardctl, not by writing the file, so this stays the single source of truth.
CARD_STATUSES = ["backlog", "in-progress", "on-hold", "done", "archived"]

# Card `type` vocabulary (schema comment above): project | program, plus the
# optional bug | idea | decision kinds already in use on existing cards.
CARD_TYPES = ["project", "program", "bug", "idea", "decision"]


def die(msg):
    print(f"cardctl: {msg}", file=sys.stderr)
    sys.exit(1)


def parse_fm(fm):
    """Minimal frontmatter parser for the card schema: scalars, inline lists
    (`tags: [a, b]`) and block lists (`paths:` then `  - item`). No deps."""
    data, key = {}, None
    for raw in fm.splitlines():
        if not raw.strip() or raw.lstrip().startswith("#"):
            continue
        if raw[:1] in (" ", "\t") and raw.strip().startswith("- "):
            if key is not None:
                data.setdefault(key, [])
                if isinstance(data[key], list):
                    data[key].append(raw.strip()[2:].strip())
            continue
        if ":" in raw:
            k, _, v = raw.partition(":")
            key, v = k.strip(), v.strip()
            if v == "":
                data[key] = []                      # block list to follow
            elif v.startswith("[") and v.endswith("]"):
                data[key] = [x.strip() for x in v[1:-1].split(",") if x.strip()]
            else:
                data[key] = v
    return data


def read_card(path):
    text = Path(path).read_text()
    if not text.startswith("---"):
        die(f"{path}: no YAML frontmatter")
    _, fm, _body = text.split("---", 2)
    return parse_fm(fm), text


def expand(p):
    return str(Path(os.path.expanduser(p)).resolve())


def unquote(v):
    """Strip a single layer of surrounding matching quotes from a scalar (the way
    `cmd_which` does), leaving unquoted values untouched."""
    v = str(v).strip()
    return v[1:-1] if len(v) >= 2 and v[0] == v[-1] and v[0] in "\"'" else v


def unwrap_wikilink(v):
    """`[[Target]]` / `[[Target|Alias]]` → `Target`; anything else returned as-is
    (after unquoting). The board wants the bare target, not the display alias."""
    v = unquote(v)
    m = re.match(r"^\[\[(.+?)\]\]$", v)
    if m:
        return m.group(1).split("|", 1)[0].strip()
    return v


def unwrap_links(v):
    """Unwrap a wikilink scalar OR a YAML list of them → a list of bare targets
    (empties dropped). For link-properties that may be multi-valued — `customer`
    (a card can serve several) or a multi-home `program`."""
    if isinstance(v, list):
        return [t for t in (unwrap_wikilink(x) for x in v) if t]
    t = unwrap_wikilink(v) if v else ""
    return [t] if t else []


def area_of(tags):
    """First `area/<slug>` tag's slug (e.g. `area/tools` → `tools`), else ''."""
    for t in tags or []:
        t = t.strip()
        if t.startswith("area/"):
            return t[len("area/"):]
    return ""


def encode_cwd(cwd):
    """Claude encodes a project cwd by replacing '/' with '-'."""
    return cwd.replace("/", "-")


def origin_of_session(sid):
    """Locate a session's transcript and return the cwd it was created in."""
    hits = glob.glob(str(PROJECTS / "*" / f"{sid}.jsonl"))
    if not hits:
        return None
    with open(hits[0]) as f:
        for line in f:
            try:
                rec = json.loads(line)
            except ValueError:
                continue
            if isinstance(rec, dict) and rec.get("cwd"):
                return rec["cwd"]
    # fall back to the encoded dir name (lossy, but better than nothing)
    return None


def ensure_primary_folder(fm):
    """If the card's primary path (paths[0], the activity folder) doesn't exist yet, create it
    (+ a stub README) so a GUI-created card launches cleanly — make a card, click ▶, work.
    Only when the parent already exists, so a typo'd path isn't fabricated deep."""
    paths = fm.get("paths") or []
    if not paths:
        return
    prim = Path(expand(paths[0]))
    if prim.exists() or not prim.parent.is_dir():
        return
    prim.mkdir()
    title = str(fm.get("title") or prim.name).strip().strip("\"'")
    readme = prim / "README.md"
    if not readme.exists():
        readme.write_text(f"# {title}\n\nActivity folder — sessions root here; working state lives here.\n")
    print(f"  created activity folder {prim}")


def build_workspace(card_path, fm, sid):
    paths = [expand(p) for p in (fm.get("paths") or [])]

    # When resuming, ensure the session's origin folder is in the workspace, else the
    # resume lookup may not find it (it is scoped to the open workspace folders).
    if sid:
        origin = origin_of_session(sid)
        if origin and expand(origin) not in paths:
            paths.insert(0, expand(origin))

    folders = [p for p in dict.fromkeys(paths) if Path(p).is_dir()]
    if not folders:
        die(f"{card_path}: no existing folders in `paths`")

    # window.title makes each generated window identifiable by its card, so `focus`
    # (and launch's window-raise) can target the right one — VS Code's resume URI has
    # no window-targeting param.
    title = unquote(fm.get("title") or Path(card_path).stem)
    settings = {"window.title": f"{title} — ${{rootName}}"}

    # Bypass is always AVAILABLE in the mode selector (armed), but no session is forced
    # into it — each tab dials up/down. Mirrors the User-settings arm; also works on
    # machines without it.
    settings["claudeCode.allowDangerouslySkipPermissions"] = True

    CACHE.mkdir(parents=True, exist_ok=True)
    ws = CACHE / f"{Path(card_path).stem}.code-workspace"
    ws.write_text(json.dumps(
        {"folders": [{"name": Path(p).name, "path": p} for p in folders], "settings": settings},
        indent=2,
    ))
    return ws, folders


def primary_context(fm):
    """First existing folder in `paths` — where this card's sessions are created (cwd)."""
    for p in (fm.get("paths") or []):
        if Path(expand(p)).is_dir():
            return expand(p)
    return None


def sessions_for_folder(folder):
    """Transcripts created with cwd=folder, newest first."""
    proj = PROJECTS / encode_cwd(folder)
    return sorted(proj.glob("*.jsonl"), key=lambda p: p.stat().st_mtime, reverse=True)


def last_active(fm):
    """Newest Claude-session activity for a card, as a timezone-aware ISO-8601 string
    (local tz — Steve is AWST), or None if the card has no sessions. The board sorts on
    this for 'most recently worked' and a live/recent badge. Considers BOTH the pinned
    `sessionId`'s transcript (it may have run outside the card's folders) and every
    transcript under the card's `paths` folders; takes the max mtime across them."""
    mtimes = []
    pin = fm.get("sessionId")
    if isinstance(pin, str) and pin.strip():
        for hit in glob.glob(str(PROJECTS / "*" / f"{pin.strip()}.jsonl")):
            mtimes.append(Path(hit).stat().st_mtime)
    for p in (fm.get("paths") or []):
        folder = expand(p)
        if Path(folder).is_dir():
            mtimes += [t.stat().st_mtime for t in sessions_for_folder(folder)]
    if not mtimes:
        return None
    return datetime.datetime.fromtimestamp(max(mtimes)).astimezone().isoformat()


def first_user_msg(path):
    """A short preview of a session's first human message (for the pick list)."""
    try:
        with open(path) as f:
            for line in f:
                try:
                    rec = json.loads(line)
                except ValueError:
                    continue
                if not (isinstance(rec, dict) and rec.get("type") == "user"):
                    continue
                c = (rec.get("message") or {}).get("content")
                if isinstance(c, list):
                    c = " ".join(p.get("text", "") for p in c
                                 if isinstance(p, dict) and p.get("type") == "text")
                c = (c or "").strip()
                if c and not c.startswith("<") and "command-" not in c[:40] \
                        and not c.lower().startswith("caveat"):
                    return c[:70]
    except OSError:
        pass
    return "(no preview)"


def pick_session(folder, sess):
    """Interactive chooser (terminal only). Returns a sid, or None for 'new'."""
    print(f"sessions under {folder}:")
    for i, p in enumerate(sess[:9], 1):
        ts = datetime.datetime.fromtimestamp(p.stat().st_mtime).strftime("%d %b %H:%M")
        print(f"  {i}) {ts}  {first_user_msg(p)}")
    print("  0) start a new session")
    try:
        choice = input("choose [1]: ").strip() or "1"
    except EOFError:
        return sess[0].stem  # non-interactive (e.g. a button) → latest
    if choice == "0":
        return None
    try:
        idx = int(choice) - 1
        if 0 <= idx < len(sess[:9]):
            return sess[idx].stem
    except ValueError:
        pass
    return sess[0].stem


def resolve_session(fm, args):
    """Decide which session to resume (sid) and why (mode). None sid → start fresh.
    Precedence: --new → fresh; pinned `sessionId` → that; else newest under the
    card's context folder (--pick to choose); else fresh (R14)."""
    if args.new:
        return None, "new (forced)"
    pin = fm.get("sessionId")
    if isinstance(pin, str) and pin.strip():
        return pin.strip(), "pinned"
    folder = primary_context(fm)
    if folder:
        sess = sessions_for_folder(folder)
        if sess:
            if args.pick:
                return pick_session(folder, sess), "picked"
            return sess[0].stem, "latest for folder"
    return None, "new (no prior session)"


def activate_vscode():
    """Bring VS Code to the front before firing the resume URI. The
    `vscode://anthropic.claude-code/open?session=` URI is delivered to whatever
    window is frontmost (no window-targeting param exists), so when launched from
    Obsidian — which is frontmost — the resume can land in the wrong window. This
    re-asserts VS Code (whose newly-opened window is its front window) as the
    frontmost app, closing the common case of the race. The deterministic fix
    (raise the specific window by title) is the separate window-targeting work."""
    try:
        subprocess.run([OSASCRIPT, "-e",
                        'tell application "Visual Studio Code" to activate'],
                       check=False, timeout=5)
    except (OSError, subprocess.SubprocessError):
        pass  # best-effort focus nudge; never block the launch on it


def cmd_launch(args):
    fm, _ = read_card(args.card)
    if str(fm.get("status") or "").strip().lower() == "archived":
        die(f"{args.card}: card is archived — run `cardctl reinstate {args.card}` first")
    ensure_primary_folder(fm)  # GUI-created card with no folder yet → create it, then launch
    sid, mode = resolve_session(fm, args)
    ws, folders = build_workspace(args.card, fm, sid)

    print(f"opening {len(folders)} folder(s):")
    for p in folders:
        print(f"  - {p}")
    subprocess.run([CODE, str(ws)], check=True)
    time.sleep(args.delay)
    activate_vscode()        # make the new VS Code window frontmost before the URI
    time.sleep(0.4)          # let the activation settle so the URI lands on it

    if sid:
        print(f"resuming session {sid}  ({mode})")
        subprocess.run([OPEN, URI.format(sid=sid)], check=True)
    else:
        print(f"starting a new session  ({mode})")
        subprocess.run([OPEN, URI_NEW], check=True)
        print(f"  → pin it later if you want with:  cardctl link {args.card}")


UUID_RE = re.compile(r"`([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12})`")


def session_date(sid):
    """Date a session ran, from its transcript mtime (for the ## Sessions log)."""
    hits = glob.glob(str(PROJECTS / "*" / f"{sid}.jsonl"))
    if hits:
        return datetime.datetime.fromtimestamp(Path(hits[0]).stat().st_mtime).strftime("%d %b %Y")
    return ""


def cmd_link(args):
    """Pin a session as the card's `sessionId` AND log it under the card's `## Sessions`
    history (newest first; an AI fills in 'what it did'). Re-pin freely — the previous pin
    stays logged. Pick the session: `--session <id>` | `--current` (the running session) |
    newest transcript under the card's folder (`--cwd` to point elsewhere)."""
    if not Path(args.card).is_file():
        die(f"{args.card}: no such card")
    if not card_under_cards_dirs(args.card):
        die(f"{args.card}: not inside a configured Cards/ folder")
    fm, text = read_card(args.card)

    if args.session:
        sid = args.session.strip()
    elif args.current:
        tx = glob.glob(str(PROJECTS / "*" / "*.jsonl"))
        if not tx:
            die("no session transcripts found")
        sid = Path(max(tx, key=lambda p: Path(p).stat().st_mtime)).stem
        print(f"current session: {sid}")
    else:
        origin = args.cwd or next((expand(p) for p in (fm.get("paths") or [])
                                   if Path(expand(p)).is_dir()), None)
        if not origin:
            die(f"{args.card}: no folder to search — pass --session <id> or --cwd")
        proj = PROJECTS / encode_cwd(origin)
        sess = sorted(proj.glob("*.jsonl"), key=lambda p: p.stat().st_mtime, reverse=True)
        if not sess:
            die(f"no sessions found under {origin} (looked in {proj}); "
                f"pass --session <id> for a session that ran elsewhere")
        sid = sess[0].stem
        print(f"newest session under {origin}: {sid}")

    old = fm.get("sessionId")
    old = old.strip() if isinstance(old, str) and old.strip() else None

    # Sessions already logged in the body (so re-pinning doesn't duplicate).
    logged = set(UUID_RE.findall(text))
    # Newest-first: the new current, then the session it displaced (if not already logged).
    add = [i for i in ([sid] + ([old] if old and old != sid else [])) if i not in logged]
    # `sessionId` (frontmatter) marks the current pin; the log is just id — date (newest first),
    # and an AI fills in the "— what it did" note. No (current) marker to go stale.
    entries = [f"- `{i}` — {session_date(i) or '?'}" for i in add]

    lines = text.splitlines(keepends=True)
    out, in_fm, seen_open, sid_set, inserted = [], False, False, False, (not entries)
    for ln in lines:
        if ln.strip() == "---":
            if not seen_open:
                seen_open = in_fm = True
                out.append(ln); continue
            if in_fm:
                if not sid_set:
                    out.append(f"sessionId: {sid}\n")
                in_fm = False
                out.append(ln); continue
        if in_fm:
            if ln.startswith("sessionId:"):
                out.append(f"sessionId: {sid}\n"); sid_set = True; continue
            out.append(ln); continue
        out.append(ln)
        if not inserted and ln.strip() == "## Sessions":
            out += [e + "\n" for e in entries]
            inserted = True
    if not inserted:  # no ## Sessions section yet — append one
        if out and not out[-1].endswith("\n"):
            out.append("\n")
        out.append("\n## Sessions\n\n")
        out += [e + "\n" for e in entries]
    Path(args.card).write_text("".join(out))
    print(f"pinned {sid}; logged {len(entries)} session(s) under ## Sessions"
          + (f" (previous {old} kept in history)" if old and old != sid else ""))


def card_under_cards_dirs(path):
    """True if `path` resolves inside one of the configured Cards/ folders — the
    guard that keeps `set-status` (and any surface delegating to it) from editing
    arbitrary files."""
    target = expand(path)
    return any(target == expand(cd) or target.startswith(expand(cd) + os.sep)
               for cd in CARDS_DIRS.values())


def set_fm_field(text, key, value):
    """Return `text` with frontmatter `key:` set to `value`, leaving the rest
    byte-for-byte (surgical single-line edit — body, other fields, quoting and key
    order untouched, so the vault git diff stays minimal). Replaces a `key:` line in
    place; if the frontmatter has none, inserts one before the closing `---`. When
    `value` is None the line is *removed* (and none inserted) — used to clear
    `archivedAt` on reinstate."""
    out, in_fm, seen_open, wrote = [], False, False, False
    for ln in text.splitlines(keepends=True):
        if ln.strip() == "---":
            if not seen_open:
                seen_open = in_fm = True
                out.append(ln); continue
            if in_fm:
                if value is not None and not wrote:
                    out.append(f"{key}: {value}\n"); wrote = True
                in_fm = False
                out.append(ln); continue
        if in_fm and ln.startswith(f"{key}:"):
            if value is not None and not wrote:
                out.append(f"{key}: {value}\n"); wrote = True
            continue  # value is None → drop the line; or a dup → drop it
        out.append(ln)
    return "".join(out)


def set_status_in_text(text, status):
    """Surgically set the frontmatter `status:` field (see {@link set_fm_field})."""
    return set_fm_field(text, "status", status)


def now_iso():
    """Timezone-aware ISO-8601 timestamp in the local tz (AWST for Steve) — the
    `archivedAt` / `lastActive` format."""
    return datetime.datetime.now().astimezone().isoformat()


# ── Card-folder moves (archive ⇄ active), shared by reconcile/archive/reinstate ──

def _count_transcripts(folder):
    """Number of session transcripts (`*.jsonl`) recorded for `folder`'s cwd."""
    proj = PROJECTS / encode_cwd(folder)
    return len(list(proj.glob("*.jsonl"))) if proj.is_dir() else 0


def _relocate_transcripts(src, dst):
    """Move `src`'s session-transcript project dir to `dst`'s, so a moved card's
    folder still resolves to its sessions (resume keeps working post-move). Returns
    the count relocated; no-op (0) when `src` has no transcripts."""
    old_proj = PROJECTS / encode_cwd(src)
    if not old_proj.is_dir():
        return 0
    new_proj = PROJECTS / encode_cwd(dst)
    new_proj.mkdir(parents=True, exist_ok=True)
    n = 0
    for item in old_proj.iterdir():
        subprocess.run(["mv", str(item), str(new_proj / item.name)], check=True)
        n += 1
    try:
        old_proj.rmdir()
    except OSError:
        pass
    return n


def _move_card_folder(card_path, src, raw_src, repo, dst, commit_msg):
    """Move a card's activity folder `src` → `dst` within its task `repo` (across the
    active/archive boundary), relocate its session transcripts, and update the card's
    `paths` line (`raw_src` → `dst`). `git mv` with a plain-move-then-add fallback for
    untracked folders; commits in `repo`. Returns the count of transcripts relocated."""
    Path(dst).parent.mkdir(parents=True, exist_ok=True)
    rel_src = src[len(repo) + 1:]
    rel_dst = dst[len(repo) + 1:]
    r = subprocess.run(["git", "-C", repo, "mv", rel_src, rel_dst])
    if r.returncode != 0:  # folder not tracked — fall back to plain move + add
        subprocess.run(["mv", src, dst], check=True)
        subprocess.run(["git", "-C", repo, "add", rel_dst], check=True)
    subprocess.run(["git", "-C", repo, "commit", "-q", "-m", commit_msg], check=True)
    n_tx = _relocate_transcripts(src, dst)
    # update the card's path (vault file; rides the vault auto-backup)
    new_text = Path(card_path).read_text().replace(f"- {raw_src}", f"- {dst}", 1)
    Path(card_path).write_text(new_text)
    return n_tx


def _all_card_files():
    """Every card `.md` across the configured Cards/ folders, sorted."""
    cards = []
    for cd in CARDS_DIRS.values():
        if cd.is_dir():
            cards += sorted(cd.glob("*.md"))
    return cards


def _live_folder_refs(exclude_card):
    """Expanded folder paths referenced by any *non-archived* card other than
    `exclude_card` — R14 Pattern B: such a folder must not be moved or deleted."""
    refs = set()
    for c in _all_card_files():
        if expand(str(c)) == expand(str(exclude_card)):
            continue
        fm, _ = read_card(c)
        if str(fm.get("status") or "").strip().lower() == "archived":
            continue
        refs.update(expand(p) for p in (fm.get("paths") or []))
    return refs


def cmd_set_status(args):
    """Set a card's lifecycle `status` — the one board-owned field cardctl writes on
    demand (R10: surfaces never edit the card file directly; they go through here).
    Flips the field only; `archived` is rejected — entering it takes `cardctl archive`
    (folder move + archivedAt), leaving it takes `reinstate`."""
    status = args.status.strip()
    if status not in CARD_STATUSES:
        die(f"invalid status {status!r} (choose: {', '.join(CARD_STATUSES)})")
    if status == "archived":
        die("use `cardctl archive <card>` to archive (it moves the folder + stamps archivedAt); "
            "`set-status archived` would only flip frontmatter")
    if not Path(args.card).is_file():
        die(f"{args.card}: no such card")
    if not card_under_cards_dirs(args.card):
        die(f"{args.card}: not inside a configured Cards/ folder")
    fm, text = read_card(args.card)
    old = str(fm.get("status") or "").strip()
    if old == status:
        print(f"{Path(args.card).name}: status already {status}")
        return
    Path(args.card).write_text(set_status_in_text(text, status))
    print(f"{Path(args.card).name}: status {old or '?'} → {status}")


def cmd_new(args):
    cards = CARDS_DIRS.get(args.domain)
    if cards is None:
        die(f"unknown domain {args.domain!r} (choose: {', '.join(CARDS_DIRS)})")
    if not re.fullmatch(r"[a-z0-9]+(?:-[a-z0-9]+)*", args.slug):
        die(f"invalid slug {args.slug!r} — kebab-case only (a-z, 0-9, hyphens)")
    if args.status not in CARD_STATUSES:
        die(f"invalid status {args.status!r} (choose: {', '.join(CARD_STATUSES)})")
    if args.type not in CARD_TYPES:
        die(f"invalid type {args.type!r} (choose: {', '.join(CARD_TYPES)})")
    if args.area:
        a = args.area[5:] if args.area.startswith("area/") else args.area
        if not re.fullmatch(r"[a-z0-9]+(?:-[a-z0-9]+)*", a):
            die(f"invalid --area {args.area!r} — expected area/<kebab-slug>")
        args.area = f"area/{a}"
    cards.mkdir(parents=True, exist_ok=True)
    dest = cards / f"{args.slug}.md"
    if dest.exists() and not args.force:
        die(f"{dest} already exists (use --force to overwrite)")

    tags = ([args.area] if args.area else []) + ([f"jira/{args.jira}"] if args.jira else [])
    extra = [expand(p) for p in (args.path or [])]

    # By default a new card gets its own activity folder, auto-created from the slug under the
    # domain's ACTIVE_ROOTS — so a plain `cardctl new` yields a launchable card (no empty `paths`).
    # paths[0] is that activity folder (sessions root/cwd here); any --path entries are ADDITIONAL
    # existing folders (e.g. a monorepo to link), appended after it and NOT auto-created.
    # --no-folder opts out (pure pointer card — paths is just the --path entries, maybe empty).
    paths = []
    if not args.no_folder:
        prim = ACTIVE_ROOTS[args.domain] / args.slug
        prim.mkdir(parents=True, exist_ok=True)
        readme = prim / "README.md"
        if not readme.exists():
            readme.write_text(f"# {args.title}\n\n**Started:** {datetime.date.today().isoformat()} "
                              "(AWST)\n\nActivity folder — sessions root here; working state lives here.\n")
        print(f"  created activity folder {prim}")
        paths.append(str(prim))
    paths += extra

    # --path entries are additional existing folders; warn (don't create) if missing.
    for p in extra:
        if not Path(p).is_dir():
            print(f"cardctl: warning — path does not exist yet: {p}", file=sys.stderr)

    # Human glance fields (shown on the board) first; plumbing (cardctl) last.
    # json.dumps gives YAML-safe double-quoting; ensure_ascii=False keeps em-dashes etc.
    # literal in the file (YAML would parse \uXXXX, but the raw card stays readable).
    def yq(s):
        return json.dumps(s or "", ensure_ascii=False)
    fm = [f"type: {args.type}", f"title: {args.title}", f"status: {args.status}",
          f"summary: {yq(args.summary)}",
          f"latest: {yq(args.latest)}",
          f"tags: [{', '.join(tags)}]"]
    if args.program:
        fm.append(f'program: "[[{args.program}]]"')
    if args.session:
        fm.append(f"sessionId: {args.session}")
    fm.append("paths:")
    fm += [f"  - {p}" for p in paths] or ["  - "]

    sessions = "\n## Sessions\n\n"
    if args.session:
        sessions += f"- `{args.session}` — {session_date(args.session) or '?'}  — (current)\n"
    body = (f"\n{BUTTON_BAR}\n\n{args.summary or '<one line; deep state lives in the activity folder>'}\n"
            f"{sessions}")
    dest.write_text("---\n" + "\n".join(fm) + "\n---\n" + body)
    print(f"created {dest}")
    if args.session:
        print(f"  pinned session {args.session}")
    print("  open it in Obsidian (Reading view) and click ▶ Launch session")


def cmd_reconcile(args):
    """R9: card status → disk. Only `archived` is filed — for cards marked **archived**,
    move their `active/<x>` folder to `archive/YYYY-MM-<x>` and update the card's path.
    `done` is deliberately NOT filed: it's complete-but-on-disk (off the board, folder
    stays in active/, trivially reopenable). Archiving is a separate, explicit step.
    Cross-repo: cards live in the vault, folders in the task repos. Dry-run by default."""
    closing = {"archived"}
    prefix = datetime.date.today().strftime("%Y-%m-")

    cards = []
    for cd in CARDS_DIRS.values():
        if cd.is_dir():
            cards += sorted(cd.glob("*.md"))

    # Folders referenced by a still-active card must NOT be archived (R14 Pattern B).
    parsed, live_refs = [], set()
    for c in cards:
        fm, text = read_card(c)
        status = str(fm.get("status") or "").strip().lower()
        paths = [expand(p) for p in (fm.get("paths") or [])]
        parsed.append((c, status, paths, fm, text))
        if status not in closing:
            live_refs.update(paths)

    todo = []
    for c, status, paths, fm, text in parsed:
        if status not in closing:
            continue
        for p, raw in zip(paths, (fm.get("paths") or [])):
            if "/active/" not in p or not Path(p).is_dir():
                continue
            if p in live_refs:
                print(f"SKIP (shared with a live card): {p}  [{c.name}]")
                continue
            repo, _, _ = p.partition("/active/")
            leaf = Path(p).name
            target = f"{repo}/archive/{prefix}{leaf}"
            todo.append((c, p, raw, repo, leaf, target, text))

    if not todo:
        print("reconcile: nothing to do.")
        return
    for c, p, raw, repo, leaf, target, text in todo:
        n_tx = _count_transcripts(p)
        tx_note = f"  (+{n_tx} session transcript(s) relocated)" if n_tx else ""
        print(f"{'APPLY' if args.apply else 'DRY '}  {p}\n        → {target}{tx_note}   [{c.name}]")
        if not args.apply:
            continue
        # Stamp archivedAt if the card was marked archived without one (e.g. via the
        # bulk menu) so the board's archive view can sort it. Do it before the move,
        # which re-reads & rewrites the card's path line.
        fm, _ = read_card(c)
        if not str(fm.get("archivedAt") or "").strip():
            c.write_text(set_fm_field(c.read_text(), "archivedAt", now_iso()))
        moved = _move_card_folder(c, p, raw, repo, target, f"Archive: {leaf}")
        note = f"  (+{moved} session transcript(s) relocated)" if moved else ""
        print(f"        moved + committed in {Path(repo).name}; card path updated{note}")
    if not args.apply:
        print("\n(dry run — rerun with --apply to perform the moves)")


def _emit(args, result, human):
    """Print a command result as JSON (board contract) or a human line."""
    if getattr(args, "json", False):
        print(json.dumps(result, ensure_ascii=False))
    else:
        print(human)


def cmd_archive(args):
    """Archive a card now (R9, board-triggered): set status→archived, stamp
    `archivedAt`, and file each active/ folder to archive/YYYY-MM-<x> (relocating its
    session transcripts). The immediate, single-card equivalent of `reconcile --apply`
    plus the archivedAt stamp. R14 Pattern B: a folder shared with a still-live card
    is NOT moved (status + archivedAt are still set), and reported under `skipped`."""
    card = args.card
    if not Path(card).is_file():
        die(f"{card}: no such card")
    if not card_under_cards_dirs(card):
        die(f"{card}: not inside a configured Cards/ folder")
    fm, text = read_card(card)
    paths = [(raw, expand(raw)) for raw in (fm.get("paths") or [])]
    live = _live_folder_refs(card)
    prefix = datetime.date.today().strftime("%Y-%m-")
    stamp = now_iso()

    # Frontmatter first; _move_card_folder re-reads & rewrites the path line afterwards.
    text = set_fm_field(text, "status", "archived")
    text = set_fm_field(text, "archivedAt", stamp)
    Path(card).write_text(text)

    moved, skipped = [], []
    for raw, p in paths:
        if "/active/" not in p or not Path(p).is_dir():
            continue
        if p in live:
            skipped.append(p)
            continue
        repo, _, _ = p.partition("/active/")
        leaf = Path(p).name
        target = f"{repo}/archive/{prefix}{leaf}"
        n_tx = _move_card_folder(card, p, raw, repo, target, f"Archive: {leaf}")
        moved.append({"from": p, "to": target, "transcripts": n_tx})

    result = {"ok": True, "status": "archived", "archivedAt": stamp,
              "moved": moved, "skipped": skipped}
    lines = [f"{Path(card).name}: archived (archivedAt {stamp})"]
    for m in moved:
        n = m["transcripts"]
        lines.append(f"  filed {m['from']}\n        → {m['to']}"
                     + (f"  (+{n} transcript(s))" if n else ""))
    for s in skipped:
        lines.append(f"  SKIP (shared with a live card): {s}")
    _emit(args, result, "\n".join(lines))


def cmd_reinstate(args):
    """Un-archive a card (the reverse of archive): set status→in-progress, clear
    `archivedAt`, and move each archive/YYYY-MM-<x> folder back to active/<x>
    (relocating transcripts back). Refuses a non-archived card; refuses when the
    active/ destination already exists (no clobber)."""
    card = args.card
    if not Path(card).is_file():
        die(f"{card}: no such card")
    if not card_under_cards_dirs(card):
        die(f"{card}: not inside a configured Cards/ folder")
    fm, text = read_card(card)
    status = str(fm.get("status") or "").strip().lower()
    if status != "archived":
        die(f"{Path(card).name}: not archived (status={status or '?'}) — "
            "reinstate only applies to archived cards")

    # Plan + validate all moves before mutating anything, so a clobber fails clean.
    plan = []
    for raw in (fm.get("paths") or []):
        p = expand(raw)
        if "/archive/" not in p or not Path(p).is_dir():
            continue
        repo, _, _ = p.partition("/archive/")
        leaf = Path(p).name
        m = re.match(r"^\d{4}-\d{2}-(.+)$", leaf)
        bare = m.group(1) if m else leaf
        dst = f"{repo}/active/{bare}"
        if Path(dst).exists():
            die(f"{dst} already exists — reinstate would clobber it")
        plan.append((raw, p, repo, dst, bare))

    text = set_fm_field(text, "status", "in-progress")
    text = set_fm_field(text, "archivedAt", None)
    Path(card).write_text(text)

    moved = []
    for raw, p, repo, dst, bare in plan:
        n_tx = _move_card_folder(card, p, raw, repo, dst, f"Reinstate: {bare}")
        moved.append({"from": p, "to": dst, "transcripts": n_tx})

    result = {"ok": True, "status": "in-progress", "moved": moved}
    lines = [f"{Path(card).name}: reinstated (status → in-progress, archivedAt cleared)"]
    for m in moved:
        n = m["transcripts"]
        lines.append(f"  restored {m['from']}\n        → {m['to']}"
                     + (f"  (+{n} transcript(s))" if n else ""))
    _emit(args, result, "\n".join(lines))


def cmd_delete(args):
    """Permanently delete an ARCHIVED card and its archived folder(s) (guarded). Only
    callable on `archived` cards; `--confirm <slug>` must equal the card's filename
    stem (engine half of the board's type-to-confirm). Removes each archive/ folder
    (git rm + commit) and its relocated transcripts, then the card note. R14 Pattern B:
    never deletes a folder still referenced by a live card."""
    card = args.card
    if not Path(card).is_file():
        die(f"{card}: no such card")
    if not card_under_cards_dirs(card):
        die(f"{card}: not inside a configured Cards/ folder")
    fm, _ = read_card(card)
    status = str(fm.get("status") or "").strip().lower()
    if status != "archived":
        die(f"{Path(card).name}: not archived (status={status or '?'}) — "
            "delete only applies to archived cards (reinstate first to keep it)")
    slug = Path(card).stem
    if args.confirm != slug:
        die(f"--confirm must equal the card slug {slug!r} to delete (got {args.confirm!r})")

    live = _live_folder_refs(card)
    deleted, skipped = [], []
    for raw in (fm.get("paths") or []):
        p = expand(raw)
        if "/archive/" not in p or not Path(p).is_dir():
            continue
        if p in live:
            skipped.append(p)
            continue
        repo, _, _ = p.partition("/archive/")
        leaf = Path(p).name
        rel = p[len(repo) + 1:]
        r = subprocess.run(["git", "-C", repo, "rm", "-r", "-q", rel])
        if r.returncode != 0:  # not tracked — plain rm then stage the removal
            subprocess.run(["rm", "-rf", p], check=True)
            subprocess.run(["git", "-C", repo, "add", "-A"], check=True)
        subprocess.run(["git", "-C", repo, "commit", "-q", "-m", f"Delete: {leaf}"], check=True)
        proj = PROJECTS / encode_cwd(p)
        if proj.is_dir():
            subprocess.run(["rm", "-rf", str(proj)], check=True)
        deleted.append(p)

    Path(card).unlink()  # remove the card note from the vault

    result = {"ok": True, "deleted": deleted, "skipped": skipped, "card": str(Path(card).resolve())}
    lines = [f"{Path(card).name}: DELETED"]
    for d in deleted:
        lines.append(f"  removed folder {d}")
    for s in skipped:
        lines.append(f"  SKIP (shared with a live card): {s}")
    _emit(args, result, "\n".join(lines))


# ── deploy ────────────────────────────────────────────────────────────────────
# Single-source the deployable surfaces (R10 "one management home"): the canonical
# copies live in this repo under deploy/; `deploy` pushes them out to each vault and
# to ~/bin. Surface files (board.base, card.md) are copied; the shared .obsidian/*.json
# files are MERGED by id/key so a vault's own settings (and other plugins' config) are
# never clobbered. Idempotent — only writes when content actually changes.

# Source tree: the repo copy when run from it, else the canonical work home (R10).
REPO = Path(__file__).resolve().parent
if not (REPO / "deploy").is_dir():
    REPO = Path.home() / "Source/work/yambay-steveg/ai-skills/session-cards"
DEPLOY_SRC = REPO / "deploy"
CARDCTL_SRC = REPO / "cardctl"
HOOK_SRC = REPO.parent / "bin" / "session-start-hook.sh"
BIN = Path.home() / "bin"
VAULT_ROOTS = {d: cards.parent for d, cards in CARDS_DIRS.items()}


def _load_json(p):
    p = Path(p)
    return json.loads(p.read_text()) if p.is_file() else {}


def merge_list_by_key(existing, ours, key="id"):
    """Merge `ours` into `existing` by `key`: our version replaces a match in place,
    new items append, everything else is preserved untouched. Returns (merged, changed)."""
    ours_by = {it[key]: it for it in ours}
    out, seen = [], set()
    for it in existing:
        k = it.get(key)
        if k in ours_by:
            out.append(ours_by[k]); seen.add(k)
        else:
            out.append(it)
    for it in ours:
        if it[key] not in seen:
            out.append(it)
    return out, out != existing


def merge_templater(existing, frag):
    """Ensure the folder-template wiring is present without clobbering other Templater
    settings. Sets the enabling flags, keeps an existing templates_folder if already set,
    and merges our folder_templates entry by `folder`. Returns (merged, changed)."""
    out = dict(existing)
    out.setdefault("templates_folder", frag["templates_folder"])
    out["trigger_on_file_creation"] = frag["trigger_on_file_creation"]
    out["enable_folder_templates"] = frag["enable_folder_templates"]
    ft, ours = list(out.get("folder_templates") or []), frag["folder_templates"]
    out["folder_templates"], _ = merge_list_by_key(ft, ours, key="folder")
    return out, out != existing


# Each surface: (label, dest-relative-to-vault, kind, source). kind drives the merge.
DEPLOY_SURFACES = [
    ("board.base",     "Cards/board.base",       "copy", "Cards/board.base"),
    ("card template",  "Templates/card.md",      "copy", "Templates/card.md"),
    ("shell commands", ".obsidian/plugins/obsidian-shellcommands/data.json",
     "array:shell_commands", "fragments/shellcommands.commands.json"),
    ("meta-bind buttons", ".obsidian/plugins/obsidian-meta-bind-plugin/data.json",
     "array:buttonTemplates", "fragments/metabind.buttons.json"),
    ("templater config", ".obsidian/plugins/templater-obsidian/data.json",
     "templater", "fragments/templater.folder-template.json"),
]


def _deploy_surface(vault, dest_rel, kind, src_rel, apply):
    """Compute (and optionally apply) one surface. Returns 'create' | 'update' |
    'unchanged' | a 'skip: …' note."""
    dst = vault / dest_rel
    src = DEPLOY_SRC / src_rel
    if not src.is_file():
        return f"skip: missing source {src}"

    if kind == "copy":
        new_text = src.read_text()
        if dst.is_file() and dst.read_text() == new_text:
            return "unchanged"
        action = "update" if dst.is_file() else "create"
        if apply:
            dst.parent.mkdir(parents=True, exist_ok=True)
            dst.write_text(new_text)
        return action

    # JSON merge surfaces — never clobber sibling settings.
    if kind.startswith("array:") and not dst.parent.is_dir():
        return "skip: plugin not installed"
    existing = _load_json(dst)
    ours = json.loads(src.read_text())
    if kind.startswith("array:"):
        prop = kind.split(":", 1)[1]
        merged, changed = merge_list_by_key(existing.get(prop, []), ours)
        new = dict(existing); new[prop] = merged
    elif kind == "templater":
        new, changed = merge_templater(existing, ours)
    else:
        return f"skip: unknown kind {kind}"
    if not changed:
        return "unchanged"
    action = "update" if dst.is_file() else "create"
    if apply:
        dst.parent.mkdir(parents=True, exist_ok=True)
        dst.write_text(json.dumps(new, indent=2) + "\n")
    return action


def _deploy_bin(apply):
    """Sync the engine + hook to ~/bin (global, not per-domain). Returns [(name, action)]."""
    out = []
    for src, name in [(CARDCTL_SRC, "cardctl"), (HOOK_SRC, "session-start-hook.sh")]:
        dst = BIN / name
        if not Path(src).is_file():
            out.append((name, f"skip: missing source {src}")); continue
        new_text = Path(src).read_text()
        if dst.is_file() and dst.read_text() == new_text:
            out.append((name, "unchanged")); continue
        action = "update" if dst.is_file() else "create"
        if apply:
            BIN.mkdir(parents=True, exist_ok=True)
            dst.write_text(new_text)
            os.chmod(dst, 0o755)
        out.append((name, action))
    return out


def cmd_deploy(args):
    if not DEPLOY_SRC.is_dir():
        die(f"deploy sources not found at {DEPLOY_SRC} (run from the ai-skills repo)")
    domains = list(CARDS_DIRS) if args.domain == "all" else [args.domain]
    tag = "APPLY" if args.apply else "DRY "
    any_change = False

    for d in domains:
        vault = VAULT_ROOTS[d]
        print(f"\n{d}  ({vault})")
        if not vault.is_dir():
            print(f"  skip: vault not found"); continue
        for label, dest_rel, kind, src_rel in DEPLOY_SURFACES:
            action = _deploy_surface(vault, dest_rel, kind, src_rel, args.apply)
            any_change |= action in ("create", "update")
            print(f"  {tag}  {action:9}  {label:18}  {dest_rel}")

    print(f"\n~/bin  ({BIN})")
    for name, action in _deploy_bin(args.apply):
        any_change |= action in ("create", "update")
        print(f"  {tag}  {action:9}  {name}")

    if not args.apply and any_change:
        print("\n(dry run — rerun with --apply to write the changes)")
    elif not any_change:
        print("\ndeploy: everything already up to date.")


CACHE_RE = re.compile(r"<!--\s*card:\s*(.+?)\s*-->")   # legacy README marker (migrated away from)
CARD_DOTFILE = ".card"


def card_matches_folder(fm, folder):
    """True if the card's paths include `folder` (or `folder` is inside one)."""
    folder = expand(folder)
    for p in (fm.get("paths") or []):
        ep = expand(p)
        if folder == ep or folder.startswith(ep + "/"):
            return True
    return False


def find_card_for(folder):
    """Reverse-lookup the card whose `paths` cover `folder` (R: session→card link).
    Fast path: a validated card path in a `.card` dotfile in the folder.
    Fallback: scan every Cards/ dir. Single source of truth = the cards' `paths`."""
    folder = expand(folder)
    dot = Path(folder) / CARD_DOTFILE
    if dot.is_file():
        cached = dot.read_text().strip()
        if cached and Path(cached).is_file():
            fm, _ = read_card(cached)
            if card_matches_folder(fm, folder):   # validate — cache can go stale (cross-repo)
                return Path(cached)
    for cd in CARDS_DIRS.values():
        if cd.is_dir():
            for c in sorted(cd.glob("*.md")):
                fm, _ = read_card(c)
                if card_matches_folder(fm, folder):
                    return c
    return None


def write_card_cache(folder, card_path):
    """Record/refresh the card back-pointer in a dedicated `.card` dotfile — a local cache that
    never touches the folder's notes (R10: 'never touch a vault's notes'). Idempotent (no write,
    no git churn, if already correct). Also migrates away any legacy `<!-- card: … -->` marker an
    older cardctl wrote into the folder's README.md."""
    dot = Path(folder) / CARD_DOTFILE
    if not (dot.is_file() and dot.read_text().strip() == str(card_path)):
        dot.write_text(str(card_path) + "\n")
    # one-time migration: strip a legacy marker so it stops polluting real READMEs/specs.
    readme = Path(folder) / "README.md"
    if readme.is_file():
        text = readme.read_text()
        if CACHE_RE.search(text):
            kept = [l for l in text.splitlines() if not CACHE_RE.search(l)]
            readme.write_text("\n".join(kept) + ("\n" if text.endswith("\n") else ""))


def open_actions(folder, limit=6):
    """Unchecked `- [ ]` items from the folder README's `## Open actions` (if any)."""
    readme = Path(folder) / "README.md"
    if not readme.is_file():
        return []
    out, in_sec = [], False
    for l in readme.read_text().splitlines():
        if l.startswith("## "):
            in_sec = l.strip().lower().startswith("## open")
            continue
        if in_sec and l.strip().startswith("- [ ]"):
            out.append(l.strip())
    return out[:limit]


def cmd_which(args):
    folder = expand(args.folder or os.getcwd())
    card = find_card_for(folder)
    if not card:
        if not args.quiet:
            print(f"cardctl: no card references {folder}", file=sys.stderr)
        sys.exit(1)
    if args.record:
        write_card_cache(folder, str(card))
    if args.path_only:
        print(str(card))
        return
    fm, _ = read_card(card)
    def unq(v):
        v = str(v).strip()
        return v[1:-1] if len(v) >= 2 and v[0] == v[-1] and v[0] in "\"'" else v
    print(f"Active card: {unq(fm.get('title', card.stem))}  [{card}]")
    if fm.get("status"):
        print(f"status: {unq(fm['status'])}")
    if fm.get("latest"):
        print(f"latest: {unq(fm['latest'])}")
    acts = open_actions(folder)
    if acts:
        print("open actions:")
        for a in acts:
            print(f"  {a}")


def card_to_dict(path, source):
    """The board's card model for one card file (scalars unquoted, wikilinks
    unwrapped, `area` derived). `source` is the vault domain key (work/personal)."""
    fm, _ = read_card(path)
    tags = fm.get("tags") if isinstance(fm.get("tags"), list) else []
    paths = fm.get("paths") if isinstance(fm.get("paths"), list) else []
    p = Path(path)
    return {
        "filePath": str(p.resolve()),
        "fileName": p.stem,
        "title": unquote(fm.get("title") or p.stem),
        "status": unquote(fm.get("status") or ""),
        "summary": unquote(fm.get("summary") or ""),
        "latest": unquote(fm.get("latest") or ""),
        "tags": [t.strip() for t in tags],
        "program": unwrap_wikilink(fm.get("program") or ""),
        "project": unwrap_wikilink(fm.get("project") or ""),
        "customer": unwrap_links(fm.get("customer")),
        "sessionId": unquote(fm.get("sessionId") or ""),
        "paths": [str(x).strip() for x in paths],
        "area": area_of(tags),
        "source": source,
        "lastActive": last_active(fm),
        "archivedAt": unquote(fm.get("archivedAt") or ""),
    }


def cmd_list(args):
    """Read interface: enumerate every card across all CARDS_DIRS. With --json,
    emit a JSON array the board can map straight onto its card model; otherwise a
    brief human listing (title — status)."""
    cards = []
    for source, cd in CARDS_DIRS.items():
        if cd.is_dir():
            for c in sorted(cd.glob("*.md")):
                cards.append(card_to_dict(c, source))
    if args.json:
        print(json.dumps(cards, ensure_ascii=False))
    else:
        for c in cards:
            print(f"{c['title']} — {c['status'] or '?'}")


# ── Hammerspoon window enumeration ─────────────────────────────────────────────
# The deterministic engine for window targeting is Hammerspoon: `hs -c '<lua>'`
# runs Lua in the running Hammerspoon and prints the return value. We enumerate the
# VS Code (`Code`) windows and read each one's title, which `build_workspace` stamps
# as "<card title> — <rootName>" (VS Code shows "<title> — <rootName> (Workspace)",
# plus " — Modified" when the window is dirty). The "<rootName>" segment is the card
# slug (== the activity-folder basename == the card filename stem).

# Lua: collect {id,title} for every window whose app is "Code", as a JSON array.
_HS_LIST_WINDOWS_LUA = (
    'local t={} for _,w in ipairs(hs.window.allWindows()) do '
    'local a=w:application() if a and a:name()=="Code" then '
    't[#t+1]={id=w:id(), title=w:title() or ""} end end '
    'return hs.json.encode(t)'
)


class HsUnavailable(Exception):
    """Hammerspoon couldn't be driven (not installed, not running / ipc port
    unreachable, non-zero exit, or unparseable output). Carries a short reason."""


def _run_hs(lua):
    """Run a Lua snippet via `hs -c` and return its stdout. Raises HsUnavailable on
    any failure. Factored out so tests can monkeypatch the subprocess call."""
    try:
        # stdin=DEVNULL is essential: when spawned non-interactively (e.g. the board's
        # Node server → cardctl → hs), `hs` blocks reading an open stdin pipe and times
        # out. Closing stdin makes it evaluate and return immediately.
        r = subprocess.run(
            [HS, "-c", lua],
            stdin=subprocess.DEVNULL,
            capture_output=True,
            text=True,
            timeout=10,
        )
    except FileNotFoundError:
        raise HsUnavailable("hs (Hammerspoon CLI) not found")
    except (OSError, subprocess.SubprocessError) as e:
        raise HsUnavailable(f"could not run hs: {e}")
    out, err = (r.stdout or "").strip(), (r.stderr or "").strip()
    # `hs` prints an ipc message-port error to stdout/stderr when Hammerspoon isn't
    # running (or the ipc module isn't loaded); surface that as unavailable, not data.
    if "message port" in (out + err).lower():
        raise HsUnavailable("Hammerspoon not running (ipc message port unreachable)")
    if r.returncode != 0:
        raise HsUnavailable(err or out or f"hs exited {r.returncode}")
    # Hammerspoon prints console/preamble lines (e.g. "-- Loading extension: json")
    # ahead of a snippet's return value the first time an extension lazy-loads —
    # drop those `--` lines so the caller parses only the actual return value.
    return "\n".join(
        ln for ln in out.splitlines() if not ln.lstrip().startswith("--")
    ).strip()


def hs_code_windows():
    """Enumerate open VS Code windows via Hammerspoon. Returns a list of
    {"id": int, "title": str}. Raises HsUnavailable on any engine failure."""
    out = _run_hs(_HS_LIST_WINDOWS_LUA)
    try:
        data = json.loads(out) if out else []
    except ValueError:
        raise HsUnavailable(f"unparseable hs output: {out[:80]!r}")
    if not isinstance(data, list):
        raise HsUnavailable("unexpected hs output (not a list)")
    wins = []
    for w in data:
        if isinstance(w, dict) and "id" in w:
            wins.append({"id": int(w["id"]), "title": str(w.get("title") or "")})
    return wins


def slug_from_window_title(title):
    """Parse the card slug out of a VS Code window title.

    VS Code renders our generated windows as "<card title> — <rootName> (Workspace)",
    with a trailing " — Modified" when the window is dirty. The "<rootName>" segment is
    the card slug. Strip the trailing " — Modified" then " (Workspace)", then take the
    substring after the LAST " — " (em-dash, U+2014, space-padded) so a card title that
    itself contains " — " is handled. Returns None when there's no " — " separator (e.g.
    a manually-opened folder window)."""
    t = (title or "").strip()
    SEP = " — "  # space + em-dash + space
    for suffix in (SEP + "Modified", " (Workspace)"):
        if t.endswith(suffix):
            t = t[: -len(suffix)].rstrip()
    idx = t.rfind(SEP)
    if idx == -1:
        return None
    return t[idx + len(SEP):].strip() or None


def stem_to_card():
    """Map {card filename stem: card filepath} across every CARDS_DIRS folder — for
    resolving a window's slug back to its card file."""
    out = {}
    for cd in CARDS_DIRS.values():
        if Path(cd).is_dir():
            for c in sorted(Path(cd).glob("*.md")):
                out.setdefault(c.stem, c)
    return out


def cmd_windows(args):
    """List the open VS Code windows (via Hammerspoon) mapped to their cards. The
    board reads `--json` to drive its session panel (open vs recently-closed). The
    JSON is an OBJECT, not a bare array, so the board can distinguish "no windows
    open" (available:true, windows:[]) from "engine unavailable" (available:false) —
    in which case we still exit 0 so the board degrades rather than hard-erroring."""
    try:
        wins = hs_code_windows()
    except HsUnavailable as e:
        if args.json:
            print(json.dumps({"available": False, "error": str(e), "windows": []},
                             ensure_ascii=False))
        else:
            print(f"cardctl: windows unavailable: {e}", file=sys.stderr)
        return
    by_stem = stem_to_card()
    rows = []
    for w in wins:
        slug = slug_from_window_title(w["title"])
        card = by_stem.get(slug) if slug else None
        rows.append({
            "id": w["id"], "title": w["title"],
            "slug": slug,
            "filePath": str(card.resolve()) if card else None,
        })
    if args.json:
        print(json.dumps({"available": True, "windows": rows}, ensure_ascii=False))
    else:
        if not rows:
            print("(no VS Code windows open)")
        for r in rows:
            print(f"  {r['id']}  {r['slug'] or '(unmatched)'}  — {r['title']}")


def _focus_by_id(win_id):
    """Focus a window by its Hammerspoon id. Returns True on success, False if the
    window is gone; raises HsUnavailable if the engine itself can't be driven."""
    out = _run_hs(f'local w=hs.window.get({int(win_id)}); '
                  'if w then w:focus(); return "ok" end return "nf"')
    return out == "ok"


def _focus_by_id_for_card(slug):
    """Best-effort deterministic focus: enumerate windows via Hammerspoon, find the
    one whose mapped slug matches this card's slug, and focus it by id. Returns True
    if a matching window was focused, False if none matched. Raises HsUnavailable if
    Hammerspoon can't be driven (so the caller falls back to AppleScript)."""
    for w in hs_code_windows():
        if slug_from_window_title(w["title"]) == slug:
            return _focus_by_id(w["id"])
    return False


def cmd_focus(args):
    """Bring the VS Code window for a card to the front (the deterministic
    window-targeting primitive; complements launch's best-effort activate nudge).

    Prefers Hammerspoon: enumerate the `Code` windows, match the one whose title maps
    to this card's slug (the card filename stem == the activity-folder basename, which
    `build_workspace` stamps into `window.title`), and focus it by id. If Hammerspoon
    is unavailable OR no window matches, fall back to driving macOS System Events:
    set the `Code` process frontmost, then AXRaise the window whose title contains the
    card title. The AppleScript path needs Accessibility permission at runtime — if it
    fails (perm not granted, no match), we print a clear note and return rather than
    crash. Best-effort by design."""
    fm, _ = read_card(args.card)
    title = unquote(fm.get("title") or Path(args.card).stem)
    slug = Path(args.card).stem

    # Preferred: deterministic focus-by-id via Hammerspoon.
    try:
        if _focus_by_id_for_card(slug):
            print(f"focused VS Code window for {title!r} (by id)")
            return
        # Hammerspoon worked but no window matched — fall through to AppleScript.
    except HsUnavailable:
        pass  # engine unavailable — fall back to AppleScript AXRaise-by-title

    # AppleScript: raise the first Code window whose title contains the card title.
    # Escape double quotes/backslashes in the title for embedding in the script.
    safe = title.replace("\\", "\\\\").replace('"', '\\"')
    script = f'''
tell application "System Events"
    if not (exists process "Code") then error "VS Code is not running"
    tell process "Code"
        set frontmost to true
        repeat with w in windows
            if name of w contains "{safe}" then
                perform action "AXRaise" of w
                return
            end if
        end repeat
        error "no VS Code window titled like " & "{safe}"
    end tell
end tell
'''
    try:
        r = subprocess.run([OSASCRIPT, "-e", script],
                           capture_output=True, text=True, timeout=10)
    except (OSError, subprocess.SubprocessError) as e:
        print(f"cardctl: focus failed to run osascript ({e}); "
              "is this macOS?", file=sys.stderr)
        return
    if r.returncode != 0:
        # Common cause: Accessibility permission not granted to the launcher.
        print(f"cardctl: could not raise the window for {title!r}: "
              f"{r.stderr.strip() or 'unknown error'}\n"
              "  (focus needs macOS Accessibility permission for the launching app — "
              "System Settings → Privacy & Security → Accessibility.)", file=sys.stderr)
    else:
        print(f"focused VS Code window for {title!r}")


# ── set: the validated metadata writer (area/program/raised-at/tags) ────────────
# Backs the /card-model skill's "apply-on-confirm" fixes. Scope is deliberately the
# additive/corrective link-properties + facet tags — reversible metadata. status stays
# with set-status; rename/move of *notes* stays out (that's an Obsidian-API job). Adding
# a link-property *value* to a card is a create/append/edit, so a filesystem write is
# correct here (the Obsidian-API requirement is only for renaming/moving notes).

def _format_tag_block(tags, inline):
    if inline:
        return "tags: [" + ", ".join(tags) + "]\n"
    return "tags:\n" + "".join(f"  - {t}\n" for t in tags)


def set_tags_in_text(text, tags):
    """Replace the frontmatter `tags:` with `tags` (existing inline-vs-block form
    preserved; inserts an inline `tags:` before the closing fence if none exists).
    Surgical like {@link set_fm_field} — only the tags lines change."""
    lines = text.splitlines(keepends=True)
    out, in_fm, seen_open, done, i = [], False, False, False, 0
    while i < len(lines):
        ln = lines[i]
        if ln.strip() == "---":
            if not seen_open:
                seen_open = in_fm = True
                out.append(ln); i += 1; continue
            if in_fm:
                if not done:
                    out.append(_format_tag_block(tags, inline=True)); done = True
                in_fm = False
                out.append(ln); i += 1; continue
        if in_fm and ln.startswith("tags:"):
            inline = bool(ln.partition(":")[2].strip())  # `tags: [..]` vs block
            if not done:
                out.append(_format_tag_block(tags, inline)); done = True
            i += 1
            if not inline:  # drop the trailing block-list items
                while i < len(lines) and lines[i][:1] in (" ", "\t") \
                        and lines[i].lstrip().startswith("- "):
                    i += 1
            continue
        out.append(ln); i += 1
    return "".join(out)


def set_paths_in_text(text, paths):
    """Replace the frontmatter `paths:` block list with `paths` (always block form —
    one `  - <abs>` line each). Surgical like {@link set_tags_in_text}: only the paths
    lines change. Inserts a `paths:` block before the closing fence if none exists."""
    lines = text.splitlines(keepends=True)
    out, in_fm, seen_open, done, i = [], False, False, False, 0
    block = "paths:\n" + "".join(f"  - {p}\n" for p in paths)
    while i < len(lines):
        ln = lines[i]
        if ln.strip() == "---":
            if not seen_open:
                seen_open = in_fm = True
                out.append(ln); i += 1; continue
            if in_fm:
                if not done:
                    out.append(block); done = True
                in_fm = False
                out.append(ln); i += 1; continue
        if in_fm and ln.startswith("paths:"):
            if not done:
                out.append(block); done = True
            i += 1
            # drop the existing block-list items (`  - ...`) and any empty placeholder
            while i < len(lines) and lines[i][:1] in (" ", "\t") \
                    and lines[i].lstrip().startswith("-"):
                i += 1
            continue
        out.append(ln); i += 1
    return "".join(out)


def cmd_set(args):
    """Write a card's metadata: area/* facet, additional facet tags, and the
    `program:`/`raised-at:` home/provenance link-properties. The single validated
    writer behind the skill's apply-on-confirm fixes (R10 — surfaces don't edit files).
    Refuses anything outside a configured Cards/ folder; never touches status."""
    if not Path(args.card).is_file():
        die(f"{args.card}: no such card")
    if not card_under_cards_dirs(args.card):
        die(f"{args.card}: not inside a configured Cards/ folder")
    fm, text = read_card(args.card)
    changes = []

    tags = [t.strip() for t in (fm.get("tags") if isinstance(fm.get("tags"), list) else [])]
    new_tags = list(tags)
    if args.area:
        a = args.area if args.area.startswith("area/") else f"area/{args.area}"
        new_tags = [t for t in new_tags if not t.startswith("area/")] + [a]
        changes.append(("area", a))
    for raw in (args.add_area or []):
        a = raw if raw.startswith("area/") else f"area/{raw}"
        if a not in new_tags:
            new_tags.append(a); changes.append(("+tag", a))
    for t in (args.add_tag or []):
        if t not in new_tags:
            new_tags.append(t); changes.append(("+tag", t))
    for t in (args.remove_tag or []):
        if t in new_tags:
            new_tags.remove(t); changes.append(("-tag", t))
    if new_tags != tags:
        text = set_tags_in_text(text, new_tags)

    if args.program is not None:
        text = set_fm_field(text, "program", f'"[[{unwrap_wikilink(args.program)}]]"')
        changes.append(("program", unwrap_wikilink(args.program)))
    if args.raised_at is not None:
        text = set_fm_field(text, "raised-at", f'"[[{unwrap_wikilink(args.raised_at)}]]"')
        changes.append(("raised-at", unwrap_wikilink(args.raised_at)))
    if args.customer is not None:
        text = set_fm_field(text, "customer", f'"[[{unwrap_wikilink(args.customer)}]]"')
        changes.append(("customer", unwrap_wikilink(args.customer)))

    # paths axis (#14): absolute folders, not wikilinks — a filesystem write is correct.
    # Appends go after paths[0] (the primary/cwd folder is preserved); a missing folder
    # warns but doesn't fail (mirrors `cmd_new`); refuse to strip the last remaining path.
    paths = [str(p).strip() for p in (fm.get("paths") if isinstance(fm.get("paths"), list) else [])]
    new_paths = list(paths)
    for raw in (args.add_path or []):
        p = expand(raw)
        if p in new_paths:
            continue  # idempotent
        new_paths.append(p)
        changes.append(("+path", p))
        if not Path(p).is_dir():
            print(f"cardctl: warning — path does not exist yet: {p}", file=sys.stderr)
    for raw in (args.remove_path or []):
        p = expand(raw)
        target = p if p in new_paths else (raw if raw in new_paths else None)
        if target is None:
            print(f"cardctl: warning — path not on card, skipping: {raw}", file=sys.stderr)
            continue
        new_paths.remove(target)
        changes.append(("-path", target))
    if paths and not new_paths:
        die("refusing to remove the last path (a card with no paths can't launch)")
    if new_paths != paths:
        text = set_paths_in_text(text, new_paths)

    if not changes:
        print(f"{Path(args.card).name}: no changes"); return
    Path(args.card).write_text(text)
    for k, v in changes:
        print(f"{Path(args.card).name}: {k} = {v}")


# ── lint: deterministic drift detection over the card store ──────────────────────
# Emits FACTS only (the skill applies judgement). Each finding: card, code, severity
# (error|warn|heuristic), detail, optional fix command, auto_safe hint. Reusable by the
# board / CI, not just the /card-model skill.

LINT_SEVERITY_RANK = {"error": 0, "warn": 1, "heuristic": 2}
VAULT_IGNORE_DIRS = {".obsidian", ".trash", ".git", "node_modules"}
# Scaffolding/tooling files that live in many folders by design and are never wikilink
# targets — excluded from the basename-collision check so they don't drown real clashes.
COLLISION_IGNORE_STEMS = {"README", "CLAUDE", "AGENTS", "index"}


def _vault_root_for_card(card_path):
    """The vault root (Cards/'s parent) whose Cards/ folder holds this card, else None."""
    cp = expand(card_path)
    for cd in CARDS_DIRS.values():
        if cp.startswith(expand(cd) + os.sep):
            return Path(cd).parent
    return None


def _source_for_card(card_path):
    """The Domain key (work/personal) whose Cards/ folder holds this card, else ''."""
    cp = expand(card_path)
    for source, cd in CARDS_DIRS.items():
        if cp.startswith(expand(cd) + os.sep):
            return source
    return ""


def _vault_notes(vault_root):
    """{note-stem: [paths]} for every .md under `vault_root` (skipping dotfolders /
    .trash / node_modules). Backs link-resolution + basename-collision checks."""
    idx = {}
    root = Path(vault_root)
    for p in root.rglob("*.md"):
        parts = p.relative_to(root).parts[:-1]
        if any(d in VAULT_IGNORE_DIRS or d.startswith(".") for d in parts):
            continue
        idx.setdefault(p.stem, []).append(p)
    return idx


def _finding(card, code, severity, detail, source="", fix=None, auto_safe=False):
    return {"card": card, "source": source, "code": code, "severity": severity,
            "detail": detail, "fix": fix, "auto_safe": auto_safe}


def cmd_lint(args):
    """Check cards for model drift; print a grouped report or `--json` findings."""
    if args.card:
        if not Path(args.card).is_file():
            die(f"{args.card}: no such card")
        card_files = [Path(args.card)]
    else:
        card_files = _all_card_files()

    cards = [(c, *read_card(c)) for c in card_files]  # (path, fm, text)

    note_idx = {}
    def notes_for(card_path):
        vr = _vault_root_for_card(card_path)
        if vr is None:
            return {}
        if str(vr) not in note_idx:
            note_idx[str(vr)] = _vault_notes(vr)
        return note_idx[str(vr)]

    # which areas have at least one card carrying a program (for EMPTY-PROGRAM)
    area_has_program = {}
    for c, fm, _ in cards:
        ar = area_of(fm.get("tags") if isinstance(fm.get("tags"), list) else [])
        if ar and unwrap_wikilink(fm.get("program") or "").strip():
            area_has_program[ar] = True

    findings = []
    for c, fm, text in cards:
        name = c.name
        src = _source_for_card(c)
        tags = fm.get("tags") if isinstance(fm.get("tags"), list) else []
        ar = area_of(tags)
        idx = notes_for(c)

        if not ar:
            findings.append(_finding(name, "NO-AREA", "error", "no area/* facet tag", source=src))

        if not unwrap_wikilink(fm.get("program") or "").strip() and ar and area_has_program.get(ar):
            findings.append(_finding(name, "EMPTY-PROGRAM", "warn",
                f"no program: while siblings in area/{ar} have one", source=src))

        for field in ("program", "raised-at", "customer"):
            raw = fm.get(field)
            if raw:
                for target in unwrap_links(raw):
                    if target and idx and target not in idx:
                        findings.append(_finding(name, "DANGLING-LINK", "error",
                            f"{field}: [[{target}]] resolves to no note in the vault", source=src))

        for field in ("summary", "latest", "title"):
            v = fm.get(field)
            if isinstance(v, str) and re.search(r"\[\[.+?\]\]", v):
                findings.append(_finding(name, "LINK-IN-PROSE", "warn",
                    f"wikilink buried in `{field}:` — not a rename-safe link-property", source=src))

        st = unquote(fm.get("status") or "").strip()
        if st and st not in CARD_STATUSES:
            findings.append(_finding(name, "BAD-STATUS", "error",
                f"status {st!r} not in controlled vocab ({', '.join(CARD_STATUSES)})",
                source=src, fix=f"cardctl set-status {c} <{'|'.join(CARD_STATUSES)}>"))

        if unquote(fm.get("type") or "").strip() == "plan" and not fm.get("planId"):
            findings.append(_finding(name, "MISSING-PLANID", "warn", "plan card without a planId", source=src))

        for p in (fm.get("paths") or []):
            if isinstance(p, str) and p.strip() and not Path(expand(p)).exists():
                findings.append(_finding(name, "STALE-PATH", "warn",
                    f"paths entry does not exist on disk: {p}", source=src))

        hay = " ".join(str(fm.get(k) or "") for k in ("title", "summary"))
        if re.search(r"\b(ongoing|standing|recurring)\b", hay, re.I):
            findings.append(_finding(name, "STANDING-LANGUAGE", "heuristic",
                "uses standing language — candidate for a Program/Forum note, not a card", source=src))

    # BASENAME-COLLISION — vault-wide, reported once per colliding stem per vault
    vr_source = {str(Path(expand(cd)).parent): source for source, cd in CARDS_DIRS.items()}
    scanned = {str(_vault_root_for_card(c)) for c, _, _ in cards if _vault_root_for_card(c)}
    for vr in scanned:
        for stem, paths in sorted(_vault_notes(vr).items()):
            if len(paths) > 1 and stem not in COLLISION_IGNORE_STEMS:
                rels = ", ".join(str(p.relative_to(vr)) for p in paths)
                findings.append(_finding("(vault)", "BASENAME-COLLISION", "error",
                    f"basename '{stem}' shared by {len(paths)} notes: {rels}",
                    source=vr_source.get(vr, "")))

    findings.sort(key=lambda f: (LINT_SEVERITY_RANK.get(f["severity"], 9),
                                 f["source"], f["code"], f["card"]))

    if args.json:
        print(json.dumps(findings, ensure_ascii=False))
        return
    if not findings:
        print(f"cardctl lint: {len(cards)} card(s), no drift ✓")
        return
    cur = None
    for f in findings:
        if f["severity"] != cur:
            cur = f["severity"]
            print(f"\n{cur.upper()}")
        if f["card"] == "(vault)":
            loc = f"[{f['source']} vault]" if f.get("source") else "[vault]"
        else:
            loc = f"{f['card']} ({f['source']})" if f.get("source") else f["card"]
        print(f"  [{f['code']}] {loc}: {f['detail']}")
        if f["fix"]:
            print(f"      fix: {f['fix']}")
    counts = {}
    for f in findings:
        counts[f["severity"]] = counts.get(f["severity"], 0) + 1
    summ = ", ".join(f"{counts[s]} {s}" for s in ("error", "warn", "heuristic") if s in counts)
    print(f"\n{len(findings)} finding(s) across {len(cards)} card(s): {summ}")


def main():
    ap = argparse.ArgumentParser(prog="cardctl", description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = ap.add_subparsers(dest="cmd", required=True)

    pl = sub.add_parser("launch", help="open card folders + resume or start its session")
    pl.add_argument("card")
    pl.add_argument("--new", action="store_true",
                    help="start a fresh session (ignore pin / latest)")
    pl.add_argument("--pick", action="store_true",
                    help="choose from the card's recent sessions (terminal only)")
    pl.add_argument("--delay", type=float, default=3.0,
                    help="seconds to wait after launching VSCode before firing the URI")
    pl.set_defaults(func=cmd_launch)

    pk = sub.add_parser("link", help="pin a session into the card (old pin → pastSessions history)")
    pk.add_argument("card")
    pk.add_argument("--session", help="pin this exact session id; "
                                      "needed for sessions that ran outside the card's folder")
    pk.add_argument("--current", action="store_true",
                    help="pin the CURRENT (running) session — the newest transcript across all projects")
    pk.add_argument("--cwd", help="folder to search for the newest session (default: first existing path)")
    pk.add_argument("--force", action="store_true", help="(accepted for compatibility; re-pin is always non-destructive now)")
    pk.set_defaults(func=cmd_link)

    pn = sub.add_parser("new", help="scaffold a card in the Domain vault's Cards/ folder")
    pn.add_argument("slug", help="card filename (kebab-case, no extension)")
    pn.add_argument("--title", required=True)
    pn.add_argument("--summary", help="one-line 'what this is' (shown on the board)")
    pn.add_argument("--latest", help="one-line current state and/or next step (shown on the board)")
    pn.add_argument("--path", action="append",
                    help="ADDITIONAL existing folder to link (repeatable; e.g. a monorepo). "
                         "Appended after the auto-created activity folder; not created.")
    pn.add_argument("--session", help="pin this session id (e.g. from `session-search`)")
    pn.add_argument("--jira", help="Jira key → jira/<KEY> tag")
    pn.add_argument("--area", help="area/* facet tag, e.g. area/v7")
    pn.add_argument("--program", help="program name → program: \"[[name]]\" link")
    pn.add_argument("--status", default="in-progress")
    pn.add_argument("--type", default="project",
                    help=f"one of: {', '.join(CARD_TYPES)} (default project)")
    pn.add_argument("--domain", default="work", choices=list(CARDS_DIRS))
    pn.add_argument("--make-folder", action="store_true",
                    help="(now default — the activity folder is always auto-created; accepted "
                         "for back-compat, no-op)")
    pn.add_argument("--no-folder", action="store_true",
                    help="opt out of the auto activity folder — card carries only --path entries "
                         "(may be empty; such a card won't launch)")
    pn.add_argument("--force", action="store_true", help="overwrite an existing card")
    pn.set_defaults(func=cmd_new)

    ps = sub.add_parser("set-status", help="set a card's lifecycle status (the board-owned field)")
    ps.add_argument("card")
    ps.add_argument("status", help=f"one of: {', '.join(CARD_STATUSES)}")
    ps.set_defaults(func=cmd_set_status)

    pst = sub.add_parser("set", help="set a card's metadata (area/program/raised-at/tags) — the "
                                     "validated writer behind the /card-model apply-on-confirm fixes")
    pst.add_argument("card")
    pst.add_argument("--area", help="set the area/* facet (replaces any existing area/* tag)")
    pst.add_argument("--add-area", action="append", help="add an additional area/* tag (repeatable)")
    pst.add_argument("--program", help='set program: "[[name]]" home link (repoints if present)')
    pst.add_argument("--raised-at", dest="raised_at", help='set raised-at: "[[forum]]" provenance link')
    pst.add_argument("--customer", help='set customer: "[[slug]]" stakeholder link (Customers/<slug>)')
    pst.add_argument("--add-tag", action="append", help="add a facet tag verbatim, e.g. kind/geospatial (repeatable)")
    pst.add_argument("--remove-tag", action="append", help="remove a facet tag (repeatable)")
    pst.add_argument("--add-path", action="append", metavar="FOLDER",
                     help="append a folder to the card's paths (idempotent; warns if it doesn't exist; repeatable)")
    pst.add_argument("--remove-path", action="append", metavar="FOLDER",
                     help="remove a folder from the card's paths (repeatable; refuses to strip the last one)")
    pst.set_defaults(func=cmd_set)

    plt = sub.add_parser("lint", help="check cards for model drift (dangling links, no area, "
                                      "basename collisions, links-in-prose, bad status, ...)")
    plt.add_argument("card", nargs="?", help="lint a single card (default: every card)")
    plt.add_argument("--json", action="store_true", help="emit findings as a JSON array")
    plt.set_defaults(func=cmd_lint)

    pr = sub.add_parser("reconcile",
                        help="file folders of cards marked archived (R9; dry-run by default)")
    pr.add_argument("--apply", action="store_true", help="perform the moves (default: dry run)")
    pr.set_defaults(func=cmd_reconcile)

    pa = sub.add_parser("archive",
                        help="archive a card now: status→archived, stamp archivedAt, file its folder")
    pa.add_argument("card")
    pa.add_argument("--json", action="store_true", help="emit machine-readable JSON (for the board)")
    pa.set_defaults(func=cmd_archive)

    pri = sub.add_parser("reinstate",
                         help="un-archive a card: status→in-progress, clear archivedAt, move folder back")
    pri.add_argument("card")
    pri.add_argument("--json", action="store_true", help="emit machine-readable JSON (for the board)")
    pri.set_defaults(func=cmd_reinstate)

    pdel = sub.add_parser("delete",
                          help="permanently delete an ARCHIVED card + its archived folder (guarded)")
    pdel.add_argument("card")
    pdel.add_argument("--confirm", required=True, metavar="SLUG",
                      help="must equal the card's filename stem (type-to-confirm guard)")
    pdel.add_argument("--json", action="store_true", help="emit machine-readable JSON (for the board)")
    pdel.set_defaults(func=cmd_delete)

    pd = sub.add_parser("deploy",
                        help="push the canonical surfaces (board/template/buttons/hook/engine) "
                             "to a vault + ~/bin (R10; dry-run by default)")
    pd.add_argument("domain", choices=list(CARDS_DIRS) + ["all"],
                    help="which vault to deploy to (or 'all')")
    pd.add_argument("--apply", action="store_true", help="write the changes (default: dry run)")
    pd.set_defaults(func=cmd_deploy)

    pls = sub.add_parser("list", help="list all cards across the Cards/ folders (--json for the board)")
    pls.add_argument("--json", action="store_true",
                     help="emit a JSON array (one object per card) for the board to consume")
    pls.set_defaults(func=cmd_list)

    pf = sub.add_parser("focus", help="bring the card's VS Code window to the front "
                                      "(Hammerspoon focus-by-id; AppleScript fallback)")
    pf.add_argument("card")
    pf.set_defaults(func=cmd_focus)

    pwin = sub.add_parser("windows", help="list open VS Code windows mapped to cards "
                                          "(via Hammerspoon; --json for the board)")
    pwin.add_argument("--json", action="store_true",
                      help="emit {available, windows:[…]} so the board can tell "
                           "'no windows' from 'engine unavailable'")
    pwin.set_defaults(func=cmd_windows)

    pw = sub.add_parser("which", help="which card owns a folder (reverse lookup; for the session-start hook)")
    pw.add_argument("folder", nargs="?", help="folder to resolve (default: cwd)")
    pw.add_argument("--record", action="store_true", help="cache the result as a back-pointer in the folder README")
    pw.add_argument("--path-only", action="store_true", help="print just the card file path")
    pw.add_argument("--quiet", action="store_true", help="no error if no card matches (exit 1)")
    pw.set_defaults(func=cmd_which)

    args = ap.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
